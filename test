  while true; do
    cat <<'EOF'

VPS Gateway Management
1. System self-check and security score
2. User and SSH security
3. Nginx TCP 443 gateway
4. Reality SNI route management
5. Add/remove inner Nginx SNI route
6. Vaultwarden secure access
7. S-UI secure access
8. Certificate management
9. Firewall management
10. Fail2ban / login notification
11. Docker exposure check
12. Backup / rollback
13. Uninstall / restore
0. Exit
EOF
    read -r -p "Select: " c
    case "$c" in
      1) cmd_doctor ;;
      2) echo "Commands: user-create, ssh-import-key, ssh-harden, ssh-internalize, ssh-check" ;;
      3) echo "Commands: gateway-install, gateway-check, gateway-disable" ;;
      4) cmd_reality_menu ;;
      5) echo "Commands: route-add, route-remove, route-list, route-enable, route-disable, route-check" ;;
      6) echo "Commands: vaultwarden-detect, vaultwarden-secure, vaultwarden-route-add, vaultwarden-admin-protect, vaultwarden-backup" ;;
      7) echo "Commands: sui-detect, sui-secure, sui-route-add, sui-check" ;;
      8) echo "Commands: cert-set-cloudflare, cert-issue, cert-import, cert-list, cert-status, cert-renew, cert-remove" ;;
      9) echo "Commands: firewall-check, firewall-stage, firewall-confirm, firewall-open, firewall-close, firewall-only-443" ;;
      10) echo "Commands: fail2ban-install, fail2ban-config-ssh, fail2ban-status, login-notify-enable, login-notify-disable, login-notify-test" ;;
      11) cmd_docker_check_exposure || true ;;
      12) echo "Commands: backup, backup-list, rollback, confirm, rollback-status" ;;
