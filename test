    firewall-check) cmd_firewall_check "${ARGS[@]}" ;;
    firewall-stage|firewall-only-443) cmd_firewall_stage "${ARGS[@]}" ;;
    firewall-confirm) cmd_firewall_confirm "${ARGS[@]}" ;;
    firewall-rollback) cmd_rollback --module firewall ;;
    firewall-open) cmd_firewall_open "${ARGS[@]}" ;;
    firewall-close) cmd_firewall_close "${ARGS[@]}" ;;
    fail2ban-install) cmd_fail2ban_install "${ARGS[@]}" ;;
    fail2ban-config-ssh) cmd_fail2ban_config_ssh "${ARGS[@]}" ;;
    fail2ban-status) cmd_fail2ban_status "${ARGS[@]}" ;;
    login-notify-enable) cmd_login_notify_enable "${ARGS[@]}" ;;
    login-notify-disable) cmd_login_notify_disable "${ARGS[@]}" ;;
    login-notify-test) cmd_login_notify_test "${ARGS[@]}" ;;
    docker-check-exposure) cmd_docker_check_exposure "${ARGS[@]}" ;;
    docker-list-ports) cmd_docker_list_ports "${ARGS[@]}" ;;
