      3)
        ensure_openssh_interactive || continue
        print_warning "该操作会禁用 SSH 密码登录，只允许公钥登录。请确认已经至少导入一个可用 SSH 公钥，并保持当前 SSH 会话不要关闭。"
        if confirm_prompt "确认继续执行 SSH 加固吗？"; then
          run_menu_action cmd_ssh_harden
        else
          print_info "已取消 SSH 加固操作。"
          pause_return
        fi
        ;;
      4)
        ensure_openssh_interactive || continue
        local port=""
        read -r -p "请输入 OpenSSH 内部监听端口 [默认 2222]: " port
        port="${port//$'\r'/}"
        [[ -n "$port" ]] || port="2222"
        if ! valid_port "$port"; then
          print_error "端口无效，请输入 1..65535 之间的数字。"
          pause_return
          continue
        fi
        print_warning "该操作会让 OpenSSH 只监听 127.0.0.1:${port}。请保持当前 SSH 会话不要关闭，并确认你有控制台、VNC、IPMI 或云厂商救援方式。"
        run_menu_action cmd_ssh_internalize --port "$port"
        ;;
      5)
        ensure_openssh_interactive || continue
        run_menu_action cmd_ssh_check
        ;;
      6)
        return 0
        ;;
      *)
        print_warning "无效选项，请输入 1-6 之间的数字。"
        ;;
    esac
  done
}

prompt_required() {
  local prompt="$1" value=""
  read -r -p "$prompt" value
  value="${value//$'\r'/}"
  if [[ -z "$value" ]]; then
    print_error "该输入不能为空。"
    return 1
  fi
  printf '%s' "$value"
}

prompt_optional() {
  local prompt="$1" default="${2:-}" value=""
  read -r -p "$prompt" value
  value="${value//$'\r'/}"
  [[ -n "$value" ]] || value="$default"
  printf '%s' "$value"
}

prompt_port() {
  local prompt="$1" default="${2:-}" port=""
  port="$(prompt_optional "$prompt" "$default")"
  if ! valid_port "$port"; then
    print_error "端口无效，请输入 1..65535 之间的数字。"
    return 1
  fi
  printf '%s' "$port"
}

prompt_proto() {
  local proto=""
  proto="$(prompt_optional "请输入协议 [默认 tcp]: " "tcp")"
  if [[ "$proto" != "tcp" && "$proto" != "udp" ]]; then
    print_error "协议无效，只允许 tcp 或 udp。"
    return 1
  fi
  printf '%s' "$proto"
}

install_package_apt() {
  local package="$1"
  require_root
  run apt-get update
  run apt-get install -y "$package"
}

ensure_command_interactive() {
  local command_name="$1" package_name="$2"
  have "$command_name" && return 0
  print_warning "未检测到 ${command_name}，当前操作需要安装 ${package_name}。"
  if confirm_prompt "是否现在通过 apt 安装 ${package_name}？"; then
    run_menu_action install_package_apt "$package_name"
    have "$command_name"
    return $?
  fi
  print_info "已取消安装 ${package_name}。"
  return 1
}

install_remote_script_interactive() {
  local url="$1" label="${2:-远程安装脚本}" version_arg="${3:-}"
  local tmp=""
  [[ "$url" =~ ^https:// ]] || { print_error "只允许 https URL。"; return 1; }
  print_warning "远程脚本存在风险，请确认来源可信：$url"
  confirm_prompt "是否下载并检查 ${label}？" || return 1
  tmp="$(mktemp)"
  if ! curl -fsSL "$url" -o "$tmp"; then
    rm -f "$tmp"
    print_error "下载失败：$url"
    return 1
  fi
  print_info "脚本来源：$url"
  print_info "脚本前 20 行预览："
  sed -n '1,20p' "$tmp" || true
  if confirm_prompt "确认执行该脚本吗？"; then
    local rc=0
    set +e
    if [[ -n "$version_arg" ]]; then
      bash "$tmp" "$version_arg"
      rc=$?
    else
      bash "$tmp"
      rc=$?
    fi
    set -e
    rm -f "$tmp"
    return "$rc"
  fi
  rm -f "$tmp"
  print_info "已取消执行远程脚本。"
  return 1
}

install_nginx_org_repo() {
  local branch="$1"
  require_root
  local os_id="" codename="" repo_url=""
  detect_os
  os_id="$OS_ID"
  codename="$OS_CODENAME"
  [[ -n "$codename" ]] || codename="$(lsb_release -cs 2>/dev/null || true)"
  [[ -n "$codename" ]] || { print_error "无法识别系统 codename。"; return 1; }
  case "$os_id" in
    ubuntu)
      case "$codename" in
        focal|jammy|noble) ;;
        *) print_error "nginx.org 官方源未在本脚本中确认支持当前 Ubuntu codename：$codename。请优先使用系统源 nginx-full 或自定义安装方式。"; return 1 ;;
      esac
      repo_url="http://nginx.org/packages${branch}/ubuntu"
      ;;
    debian)
      repo_url="http://nginx.org/packages${branch}/debian"
      ;;
    *)
      print_error "当前系统不是 Ubuntu/Debian，无法自动配置 nginx.org apt 源。"
      return 1
      ;;
  esac
  run apt-get update
  run apt-get install -y curl gnupg ca-certificates lsb-release
  run mkdir -p /etc/apt/keyrings
  run sh -c "curl -fsSL https://nginx.org/keys/nginx_signing.key | gpg --dearmor -o /etc/apt/keyrings/nginx-archive-keyring.gpg"
  run sh -c "printf 'deb [signed-by=/etc/apt/keyrings/nginx-archive-keyring.gpg] %s %s nginx\n' '$repo_url' '$codename' > /etc/apt/sources.list.d/nginx-org.list"
  run apt-get update
  run apt-get install -y nginx
}

cmd_nginx_dependency_menu() {
  while true; do
    print_banner "Nginx 依赖缺失"
    printf '当前系统未检测到 nginx。该功能需要 nginx 才能继续。\n\n'
    print_menu_item 1 "使用系统软件源安装 nginx-full"
    print_menu_item 2 "使用 Nginx 官方软件源安装最新版稳定版"
    print_menu_item 3 "使用 Nginx 官方 mainline 源安装最新版 mainline"
    print_menu_item 4 "指定 apt 包名安装"
    print_menu_item 5 "指定下载链接或安装脚本 URL"
    print_menu_item 6 "暂不安装，返回上一级"
    printf '\n'
    ui_line
    if ! read -r -p "请选择操作 [1-6]: " c; then
      return 1
    fi
    c="${c//$'\r'/}"
    case "$c" in
      1) run_menu_action install_package_apt nginx-full ;;
      2)
        print_warning "该操作会添加 nginx.org 官方 stable apt 源。"
        ensure_supported_os_interactive || continue
        if confirm_prompt "确认继续吗？"; then run_menu_action install_nginx_org_repo ""; fi
        ;;
      3)
        print_warning "mainline 是更新分支，适合需要最新功能的用户。该操作会添加 nginx.org 官方 mainline apt 源。"
        ensure_supported_os_interactive || continue
        if confirm_prompt "确认继续吗？"; then run_menu_action install_nginx_org_repo "/mainline"; fi
        ;;
      4)
        local package=""
        if ! package="$(prompt_required "请输入 apt 包名，例如 nginx、nginx-full、nginx-extras: ")"; then pause_return; continue; fi
        run_menu_action install_package_apt "$package"
        ;;
      5)
        local url=""
        if ! url="$(prompt_required "请输入 https 下载链接或安装脚本 URL: ")"; then pause_return; continue; fi
        ensure_curl_interactive || continue
        run_menu_action install_remote_script_interactive "$url" "Nginx 自定义安装脚本"
        ;;
      6) return 1 ;;
      *) print_warning "无效选项，请输入 1-6 之间的数字。" ;;
    esac
    if have nginx; then
      print_success "已检测到 nginx。"
      nginx -v 2>&1 || true
      nginx -t 2>/dev/null || print_warning "nginx -t 未通过，请检查配置。"
      return 0
    fi
    print_warning "仍未检测到 nginx，请继续选择安装方式或返回。"
  done
}

ensure_nginx_interactive() {
  have nginx && return 0
  cmd_nginx_dependency_menu
}

