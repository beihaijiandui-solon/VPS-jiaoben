      return 0
    fi
    c="${c//$'\r'/}"
    case "$c" in
      1)
        local github=""
        ensure_curl_interactive || continue
        read -r -p "请输入 GitHub 用户名: " github
        github="${github//$'\r'/}"
        if [[ -z "$github" ]]; then
          print_error "GitHub 用户名不能为空。"
