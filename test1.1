        ;;
      4)
        print_warning "高危操作：将卸载并同时尝试恢复 SSH 和 Nginx 配置。"
        if confirm_prompt "确认继续吗？"; then run_menu_action cmd_uninstall --keep-certs --restore-ssh --restore-nginx; else print_info "已取消卸载。"; pause_return; fi
        ;;
      5) return 0 ;;
      *) print_warning "无效选项，请输入 1-5 之间的数字。" ;;
    esac
  done
}

cmd_self_lint() {
  echo "自检开始..."
  bash -n "$SELF_PATH" || die "bash -n 失败"
  if grep -nE '^[[:space:]]*listen\[' "$SELF_PATH"; then die "检测到 Nginx listen 与 IPv6 地址粘连错误"; fi
  if grep -nE 'read -r -p "请选择操作\[' "$SELF_PATH"; then die "检测到菜单提示缺少空格"; fi
  if grep -nE '监听端口\[默认' "$SELF_PATH"; then die "检测到端口默认值提示缺少空格"; fi
  if grep -nE '后端地址\[默认' "$SELF_PATH"; then die "检测到地址默认值提示缺少空格"; fi
  if grep -nE 'tag\[默认' "$SELF_PATH"; then die "检测到 tag 默认值提示缺少空格"; fi
  echo "自检通过 ✅"
}

print_command_group() {
  local title="$1"; shift
  print_section "$title"
  printf '%s\n' "$@"
}

show_main_menu() {
  print_banner "VPS Gateway 管理面板"
  print_menu_item 1 "系统自检与安全评分"
  print_menu_item 2 "用户与 SSH 安全"
  print_menu_item 3 "Nginx TCP/UDP 443 网关"
  print_menu_item 4 "Reality SNI 路由管理"
  print_menu_item 5 "添加 / 删除内层 Nginx SNI 路由"
  print_menu_item 6 "Vaultwarden 安全接入"
  print_menu_item 7 "S-UI 安全接入"
  print_menu_item 8 "证书管理"
  print_menu_item 9 "防火墙管理"
  print_menu_item 10 "Fail2ban / 登录通知"
  print_menu_item 11 "Docker 暴露面检查"
  print_menu_item 12 "备份 / 回滚"
  print_menu_item 13 "卸载 / 恢复"
  print_menu_item 14 "退出"
  printf '\n'
  ui_line
}

cmd_menu() {
  while true; do
    show_main_menu
    if ! read -r -p "请选择操作 [1-14]: " c; then
      echo "已退出 VPS Gateway 管理面板。"
      exit 0
    fi
    c="${c//$'\r'/}"
    case "$c" in
      1) run_menu_action cmd_doctor ;;
      2) cmd_ssh_menu ;;
      3) cmd_gateway_menu ;;
      4) cmd_reality_menu ;;
      5) cmd_route_menu ;;
      6) cmd_vaultwarden_menu ;;
      7) cmd_sui_menu ;;
      8) cmd_cert_menu ;;
      9) cmd_firewall_menu ;;
      10) cmd_fail2ban_menu ;;
      11) cmd_docker_menu ;;
      12) cmd_backup_menu ;;
      13) cmd_uninstall_menu ;;
      14) echo "已退出 VPS Gateway 管理面板。"; exit 0 ;;
      *) print_warning "无效选项，请输入 1-14 之间的数字。" ;;
    esac
  done
}

dispatch() {
  case "$COMMAND" in
    help) usage ;;
    menu) cmd_menu "${ARGS[@]}" ;;
    init) cmd_init "${ARGS[@]}" ;;
    doctor) cmd_doctor "${ARGS[@]}" ;;
    report) cmd_report "${ARGS[@]}" ;;
    install-deps) cmd_install_deps "${ARGS[@]}" ;;
    user-create) cmd_user_create "${ARGS[@]}" ;;
    ssh-import-key) cmd_ssh_import_key "${ARGS[@]}" ;;
    ssh-harden) cmd_ssh_harden "${ARGS[@]}" ;;
    ssh-internalize) cmd_ssh_internalize "${ARGS[@]}" ;;
    ssh-check) cmd_ssh_check "${ARGS[@]}" ;;
    ssh-rollback) cmd_rollback --module ssh ;;
    gateway-install|gateway-enable) cmd_gateway_install "${ARGS[@]}" ;;
    gateway-disable) cmd_gateway_disable "${ARGS[@]}" ;;
    gateway-check) cmd_gateway_check "${ARGS[@]}" ;;
    gateway-rollback) cmd_rollback --module nginx ;;
    reality-check) cmd_reality_check "${ARGS[@]}" ;;
    reality-route-list) cmd_reality_route_list "${ARGS[@]}" ;;
    reality-route-add) cmd_reality_route_add "${ARGS[@]}" ;;
    reality-route-remove) cmd_reality_route_remove "${ARGS[@]}" ;;
    reality-route-set-default) cmd_reality_route_set_default "${ARGS[@]}" ;;
    reality-menu) cmd_reality_menu "${ARGS[@]}" ;;
    route-add) cmd_route_add "${ARGS[@]}" ;;
    route-remove) cmd_route_remove "${ARGS[@]}" ;;
    route-list) cmd_route_list "${ARGS[@]}" ;;
    route-check) cmd_route_check "${ARGS[@]}" ;;
    route-disable) cmd_route_disable "${ARGS[@]}" ;;
    route-enable) cmd_route_enable "${ARGS[@]}" ;;
    vaultwarden-detect) cmd_vaultwarden_detect "${ARGS[@]}" ;;
    vaultwarden-secure) cmd_vaultwarden_secure "${ARGS[@]}" ;;
    vaultwarden-route-add) cmd_vaultwarden_route_add "${ARGS[@]}" ;;
    vaultwarden-check) cmd_vaultwarden_check "${ARGS[@]}" ;;
    vaultwarden-admin-protect) cmd_vaultwarden_admin_protect "${ARGS[@]}" ;;
    vaultwarden-backup) cmd_vaultwarden_backup "${ARGS[@]}" ;;
    sui-detect) cmd_sui_detect "${ARGS[@]}" ;;
    sui-secure) cmd_sui_secure "${ARGS[@]}" ;;
    sui-route-add) cmd_sui_route_add "${ARGS[@]}" ;;
    sui-check) cmd_sui_check "${ARGS[@]}" ;;
    cert-install-acme) cmd_cert_install_acme "${ARGS[@]}" ;;
    cert-set-cloudflare) cmd_cert_set_cloudflare "${ARGS[@]}" ;;
    cert-issue) cmd_cert_issue "${ARGS[@]}" ;;
    cert-import) cmd_cert_import "${ARGS[@]}" ;;
    cert-renew) cmd_cert_renew "${ARGS[@]}" ;;
    cert-status) cmd_cert_status "${ARGS[@]}" ;;
    cert-list) cmd_cert_list "${ARGS[@]}" ;;
    cert-remove) cmd_cert_remove "${ARGS[@]}" ;;
    cert-find) cmd_cert_find "${ARGS[@]}" ;;
    firewall-check) cmd_firewall_check "${ARGS[@]}" ;;
    firewall-stage|firewall-only-443) cmd_firewall_stage "${ARGS[@]}" ;;
    firewall-confirm) cmd_firewall_confirm "${ARGS[@]}" ;;
    firewall-rollback) cmd_rollback --module firewall ;;
    firewall-open) cmd_firewall_open "${ARGS[@]}" ;;
    firewall-close) cmd_firewall_close "${ARGS[@]}" ;;
    fail2ban-install) cmd_fail2ban_install "${ARGS[@]}" ;;
    fail2ban-config-ssh) cmd_fail2ban_config_ssh "${ARGS[@]}" ;;
    fail2ban-status) cmd_fail2ban_status "${ARGS[@]}" ;;
    login-notify-enable) cmd_login_notify_enable "${ARGS[@]}" ;;
    login-notify-disable) cmd_login_notify_disable "${ARGS[@]}" ;;
    login-notify-test) cmd_login_notify_test "${ARGS[@]}" ;;
    docker-check-exposure) cmd_docker_check_exposure "${ARGS[@]}" ;;
    docker-list-ports) cmd_docker_list_ports "${ARGS[@]}" ;;
    docker-suggest-fix) cmd_docker_suggest_fix "${ARGS[@]}" ;;
    backup) cmd_backup "${ARGS[@]}" ;;
    backup-list) cmd_backup_list "${ARGS[@]}" ;;
    rollback) cmd_rollback "${ARGS[@]}" ;;
    confirm) cancel_rollback "${ARGS[0]:-all}" ;;
    rollback-status) cmd_rollback_status "${ARGS[@]}" ;;
