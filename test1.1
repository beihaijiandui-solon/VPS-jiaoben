#!/usr/bin/env bash
set -Eeuo pipefail

VERSION="0.1.0"
SELF_PATH="$(readlink -f "$0" 2>/dev/null || printf '%s' "$0")"

BASE_DIR="${VPS_GATEWAY_BASE:-/etc/vps-gateway}"
LOG_DIR="${VPS_GATEWAY_LOG:-/var/log/vps-gateway}"
NGINX_DIR="/etc/nginx"
NGINX_STREAM_DIR="/etc/nginx/stream.d"
NGINX_HTTP_DIR="/etc/nginx/conf.d"
REALITY_CONF_DEFAULT="/etc/nginx/stream-conf.d/reality443.conf"
SSH_DROPIN="/etc/ssh/sshd_config.d/99-vps-gateway.conf"

DRY_RUN=0
VERBOSE=0
ASSUME_YES=0
COMMAND=""
ARGS=()

umask 077

on_error() {
  local exit_code=$?
  local line_no=${1:-unknown}
  log "ERROR" "命令在第 ${line_no} 行执行失败；退出码=${exit_code}"
  exit "$exit_code"
}
trap 'on_error $LINENO' ERR

on_interrupt() {
  printf '\n已取消操作，正在退出。\n' >&2
  exit 130
}
trap on_interrupt INT

usage() {
  cat <<'EOF'
VPS Gateway - 模块化 VPS 安全与 TCP 443 网关管理工具
适配范围：Ubuntu 20.04 / 22.04 / 24.04 LTS

用法：
  vps-gateway                         进入中文管理面板
  vps-gateway menu                    进入中文管理面板
  vps-gateway help                    查看本帮助
  vps-gateway [全局选项] <子命令> [参数]

全局选项：
  --dry-run                           只预览将要执行的动作，不修改系统
  --verbose                           显示更详细的执行信息
  --yes, -y                           跳过普通确认；高危操作仍会做安全检查
  --help, -h                          查看本帮助

常用命令示例：
  vps-gateway doctor                  执行系统自检与安全评分
  vps-gateway install-deps --minimal  只安装最小依赖
  vps-gateway reality-menu            管理 Reality SNI 路由
  vps-gateway reality-route-list      查看 Reality SNI 路由
  vps-gateway route-list              查看内层 Nginx SNI 路由
  vps-gateway cert-status             查看证书状态
  vps-gateway docker-check-exposure   检查 Docker 公网端口暴露
  vps-gateway firewall-stage          分阶段收紧防火墙
  vps-gateway rollback-status         查看待确认的自动回滚

高危操作提醒：
  1. 不要让 OpenSSH 和 Nginx 同时直接监听公网 443。
  2. 未验证 SSH over 443 前，不要关闭公网 22。
  3. SSH、Nginx、防火墙、证书等高危模块会先备份并安排自动回滚。
  4. Reality 已占用 443 时，请使用 reality-* 命令管理路由，不要强行执行 gateway-install。

关键路径：
  配置目录：/etc/vps-gateway
  日志目录：/var/log/vps-gateway
  主程序：  /usr/local/bin/vps-gateway
  Reality： /etc/nginx/stream-conf.d/reality443.conf
EOF
}

parse_global_args() {
  while (($#)); do
    case "$1" in
      --dry-run) DRY_RUN=1; shift ;;
      --verbose) VERBOSE=1; shift ;;
      --yes|-y) ASSUME_YES=1; shift ;;
      --help|-h|help) COMMAND="help"; shift; ARGS=("$@"); return ;;
      *) COMMAND="$1"; shift; ARGS=("$@"); return ;;
    esac
  done
  COMMAND="menu"
  ARGS=()
}

log_file_for_level() {
  mkdir -p "$LOG_DIR" 2>/dev/null || true
  printf '%s/main.log' "$LOG_DIR"
}

log() {
  local level="$1"; shift
  local msg="$*"
  local ts
  local label="$level"
  local lf
  case "$level" in
    INFO) label="信息" ;;
    WARN) label="警告" ;;
    ERROR) label="错误" ;;
  esac
  ts="$(date '+%Y-%m-%d %H:%M:%S' 2>/dev/null || true)"
  lf="$(log_file_for_level)"
  if [[ -d "$(dirname "$lf")" && -w "$(dirname "$lf")" ]]; then
    printf '[%s] [%s] %s\n' "$ts" "$label" "$msg" | tee -a "$lf" >&2 || true
  else
    printf '[%s] [%s] %s\n' "$ts" "$label" "$msg" >&2
  fi
}

info() { log "INFO" "$*"; }
warn() { log "WARN" "$*"; }
die() { log "ERROR" "$*"; exit 1; }

have() { command -v "$1" >/dev/null 2>&1; }

OS_ID="unknown"
OS_VERSION_ID="unknown"
OS_CODENAME=""
OS_PRETTY_NAME="unknown"

ubuntu_codename_from_version() {
  case "${1:-}" in
    20.04*) printf 'focal' ;;
    22.04*) printf 'jammy' ;;
    24.04*) printf 'noble' ;;
    *) printf '' ;;
  esac
}

detect_os() {
  OS_ID="unknown"
  OS_VERSION_ID="unknown"
  OS_CODENAME=""
  OS_PRETTY_NAME="unknown"
  if [[ -f /etc/os-release ]]; then
    # shellcheck disable=SC1091
    . /etc/os-release
    OS_ID="${ID:-unknown}"
    OS_VERSION_ID="${VERSION_ID:-unknown}"
    OS_CODENAME="${VERSION_CODENAME:-}"
    OS_PRETTY_NAME="${PRETTY_NAME:-unknown}"
  fi
  if [[ -z "$OS_CODENAME" ]]; then
    OS_CODENAME="$(ubuntu_codename_from_version "$OS_VERSION_ID")"
  fi
}

ubuntu_version_id() {
  detect_os
  printf '%s' "$OS_VERSION_ID"
}

ubuntu_codename() {
  detect_os
  printf '%s' "$OS_CODENAME"
}

check_supported_ubuntu() {
  detect_os
  [[ "$OS_ID" == "ubuntu" ]] || return 1
  case "$OS_VERSION_ID" in
    20.04*|22.04*|24.04*) return 0 ;;
    *) return 1 ;;
  esac
}

ensure_supported_os_interactive() {
  check_supported_ubuntu && return 0
  print_warning "当前系统未明确支持：${OS_PRETTY_NAME}。本工具主要适配 Ubuntu 20.04 / 22.04 / 24.04，继续操作可能存在兼容性问题。"
  confirm_prompt "仍要继续当前操作吗？"
}

color_enabled() {
  [[ -t 1 && -z "${NO_COLOR:-}" ]]
}

color() {
  local code="$1"
  if color_enabled; then
    printf '\033[%sm' "$code"
  fi
  return 0
}

color_reset() {
  if color_enabled; then
    printf '\033[0m'
  fi
  return 0
}

ui_line() {
  printf '════════════════════════════════════════════\n'
}

print_banner() {
  local title="$1"
  printf '\n'
  color "1;36"; ui_line; color_reset
  printf '        %s\n' "$title"
  color "1;36"; ui_line; color_reset
  printf '\n'
}

print_section() {
  local title="$1"
  color "1;34"; printf '\n【%s】\n' "$title"; color_reset
}

print_menu_item() {
  local no="$1" text="$2"
  printf ' %2s. %s\n' "$no" "$text"
}

print_success() {
  color "1;32"; printf '✅ %s\n' "$*"; color_reset
}

print_warning() {
  color "1;33"; printf '⚠️  %s\n' "$*" >&2; color_reset
}

print_error() {
  color "1;31"; printf '❌ %s\n' "$*" >&2; color_reset
}

print_info() {
  color "1;36"; printf 'ℹ️  %s\n' "$*"; color_reset
}

pause_return() {
  [[ -t 0 ]] || return 0
  printf '\n按 Enter 返回上一级...'
  read -r _
}

menu_try() {
  local rc=0
  set +e
  trap - ERR
  ( trap 'exit $?' ERR; set -Eeuo pipefail; "$@" )
  rc=$?
  trap 'on_error $LINENO' ERR
  set -e
  if [[ "$rc" -ne 0 ]]; then
    print_error "当前操作执行失败，退出码：$rc。请根据上方提示处理后重试。"
  fi
  return "$rc"
}

run_menu_action() {
  menu_try "$@" || true
  pause_return
  return 0
}

run() {
  if ((VERBOSE || DRY_RUN)); then
    printf '+'
    printf ' %q' "$@"
    printf '\n'
  fi
  if ((DRY_RUN)); then
    return 0
  fi
  "$@"
}

confirm_prompt() {
  local prompt="$1"
  if ((ASSUME_YES)); then
    return 0
  fi
  read -r -p "${prompt} [y/N] " reply
  [[ "$reply" == "y" || "$reply" == "Y" || "$reply" == "yes" || "$reply" == "YES" ]]
}

danger_ack() {
  local phrase="$1"
  local prompt="$2"
  local input=""
  echo "$prompt"
  echo "请准确输入：${phrase}"
  read -r input
  [[ "$input" == "$phrase" ]]
}

require_root() {
  [[ "${EUID:-$(id -u)}" -eq 0 ]] || die "此命令必须使用 root 或 sudo 执行。"
}

init_layout() {
  run mkdir -p \
    "$BASE_DIR/modules" "$BASE_DIR/routes.d" "$BASE_DIR/certs" "$BASE_DIR/secrets" \
    "$BASE_DIR/backups/ssh" "$BASE_DIR/backups/nginx" "$BASE_DIR/backups/firewall" \
    "$BASE_DIR/backups/routes" "$BASE_DIR/backups/certs" "$BASE_DIR/backups/systemd" \
    "$BASE_DIR/backups/fail2ban" "$BASE_DIR/state" "$LOG_DIR"
  run chmod 700 "$BASE_DIR/secrets"
  run chmod 700 "$BASE_DIR/backups"
  run touch "$BASE_DIR/config.env" "$BASE_DIR/state/routes.json" "$BASE_DIR/state/modules.json" \
    "$BASE_DIR/state/rollback.json" "$BASE_DIR/state/last-check.json"
  run chmod 600 "$BASE_DIR/config.env" "$BASE_DIR/state/"*.json
}

write_file() {
  local path="$1"
  local tmp
  tmp="$(mktemp)"
  cat >"$tmp"
  if ((DRY_RUN)); then
    info "预览模式：将写入 ${path}"
    rm -f "$tmp"
    return 0
  fi
  install -m 600 "$tmp" "$path"
  rm -f "$tmp"
}

set_module_state() {
  local module="$1" state="$2" note="${3:-}"
  local file="$BASE_DIR/modules/${module}.env"
  write_file "$file" <<EOF
MODULE=${module}
STATE=${state}
UPDATED_AT=$(date -u '+%Y-%m-%dT%H:%M:%SZ')
NOTE=${note}
EOF
}

snapshot_module() {
  local module="$1"
  local dest="$BASE_DIR/backups/${module}/$(date '+%Y%m%d-%H%M%S')"
  run mkdir -p "$dest"
  case "$module" in
    ssh)
      [[ -d /etc/ssh ]] && run tar -C /etc -czf "$dest/ssh.tar.gz" ssh
      [[ -d /etc/systemd/system/ssh.socket.d ]] && run tar -C /etc/systemd/system -czf "$dest/ssh-socket.d.tar.gz" ssh.socket.d
      [[ -d /etc/systemd/system/ssh.service.d ]] && run tar -C /etc/systemd/system -czf "$dest/ssh-service.d.tar.gz" ssh.service.d
      ;;
    nginx)
      [[ -d /etc/nginx ]] && run tar -C /etc -czf "$dest/nginx.tar.gz" nginx
      ;;
    firewall)
      have ufw && run sh -c "ufw status verbose > '$dest/ufw-status.txt' || true"
      [[ -d /etc/ufw ]] && run tar -C /etc -czf "$dest/ufw.tar.gz" ufw
      have iptables-save && run sh -c "iptables-save > '$dest/iptables.v4' || true"
      have ip6tables-save && run sh -c "ip6tables-save > '$dest/iptables.v6' || true"
      ;;
    routes)
      [[ -d "$BASE_DIR/routes.d" ]] && run tar -C "$BASE_DIR" -czf "$dest/routes.d.tar.gz" routes.d state/routes.json
      [[ -d "$NGINX_STREAM_DIR" ]] && run tar -C /etc/nginx -czf "$dest/stream.d.tar.gz" stream.d
      [[ -d "$NGINX_HTTP_DIR" ]] && run tar -C /etc/nginx -czf "$dest/conf.d.tar.gz" conf.d
      ;;
    certs)
      [[ -d "$BASE_DIR/certs" ]] && run tar -C "$BASE_DIR" -czf "$dest/certs.tar.gz" certs
      ;;
    fail2ban)
      [[ -d /etc/fail2ban ]] && run tar -C /etc -czf "$dest/fail2ban.tar.gz" fail2ban
      ;;
    *)
      run tar -C "$BASE_DIR" -czf "$dest/vps-gateway-state.tar.gz" state modules routes.d config.env
      ;;
  esac
  info "已创建快照：$dest"
  printf '%s\n' "$dest"
}

latest_snapshot() {
  local module="$1"
  find "$BASE_DIR/backups/$module" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | sort | tail -n 1
}

restore_module() {
  local module="$1"
  local snap="${2:-}"
  [[ -n "$snap" ]] || snap="$(latest_snapshot "$module")"
  [[ -n "$snap" && -d "$snap" ]] || die "未找到模块快照：$module"
  info "正在从快照恢复 $module：$snap"
  case "$module" in
    ssh)
      [[ -f "$snap/ssh.tar.gz" ]] && run tar -C /etc -xzf "$snap/ssh.tar.gz"
      [[ -f "$snap/ssh-socket.d.tar.gz" ]] && run tar -C /etc/systemd/system -xzf "$snap/ssh-socket.d.tar.gz"
      [[ -f "$snap/ssh-service.d.tar.gz" ]] && run tar -C /etc/systemd/system -xzf "$snap/ssh-service.d.tar.gz"
      run systemctl daemon-reload
      reload_ssh
      ;;
    nginx)
      [[ -f "$snap/nginx.tar.gz" ]] && run tar -C /etc -xzf "$snap/nginx.tar.gz"
      reload_nginx
      ;;
    firewall)
      [[ -f "$snap/ufw.tar.gz" ]] && run tar -C /etc -xzf "$snap/ufw.tar.gz"
      have ufw && run ufw reload || true
      ;;
    routes)
      [[ -f "$snap/routes.d.tar.gz" ]] && run tar -C "$BASE_DIR" -xzf "$snap/routes.d.tar.gz"
      [[ -f "$snap/stream.d.tar.gz" ]] && run tar -C /etc/nginx -xzf "$snap/stream.d.tar.gz"
      [[ -f "$snap/conf.d.tar.gz" ]] && run tar -C /etc/nginx -xzf "$snap/conf.d.tar.gz"
      reload_nginx
      ;;
    certs)
      [[ -f "$snap/certs.tar.gz" ]] && run tar -C "$BASE_DIR" -xzf "$snap/certs.tar.gz"
      ;;
    fail2ban)
      [[ -f "$snap/fail2ban.tar.gz" ]] && run tar -C /etc -xzf "$snap/fail2ban.tar.gz"
      have systemctl && run systemctl restart fail2ban || true
      ;;
    *)
      die "未知回滚模块：$module"
      ;;
  esac
}

schedule_rollback() {
  local tag="$1" module="$2" delay="${3:-5m}" snap="$4"
  local script="$BASE_DIR/state/rollback-${tag}.sh"
  write_file "$script" <<EOF
#!/usr/bin/env bash
set -Eeuo pipefail
exec >>"$LOG_DIR/rollback.log" 2>&1
echo "[\$(date '+%F %T')] Auto rollback tag=${tag} module=${module}"
"$SELF_PATH" rollback --module "$module" --snapshot "$snap"
EOF
  run chmod 700 "$script"
  if have systemd-run; then
    run systemctl cancel "vps-gateway-rollback-${tag}.timer" 2>/dev/null || true
    run systemctl reset-failed "vps-gateway-rollback-${tag}.service" 2>/dev/null || true
    run systemctl reset-failed "vps-gateway-rollback-${tag}.timer" 2>/dev/null || true
    run systemd-run --unit="vps-gateway-rollback-${tag}" --on-active="$delay" /bin/bash "$script"
  else
    warn "未找到 systemd-run，无法安排自动回滚。"
  fi
  write_file "$BASE_DIR/state/rollback.json" <<EOF
{"tag":"$tag","module":"$module","snapshot":"$snap","delay":"$delay","created_at":"$(date -u '+%Y-%m-%dT%H:%M:%SZ')"}
EOF
  warn "已为 ${module} 安排 ${delay} 后自动回滚。验证成功后请执行：vps-gateway confirm ${tag}"
}

cancel_rollback() {
  local tag="${1:-}"
  if [[ -z "$tag" || "$tag" == "all" ]]; then
    if have systemctl; then
      systemctl list-units 'vps-gateway-rollback-*' --all --no-legend 2>/dev/null | awk '{print $1}' | while read -r unit; do
        [[ -n "$unit" ]] && run systemctl cancel "$unit" || true
      done
    fi
    write_file "$BASE_DIR/state/rollback.json" <<'EOF'
{}
EOF
    info "已取消回滚定时任务。"
    return 0
  fi
  if have systemctl; then
    run systemctl cancel "vps-gateway-rollback-${tag}.timer" 2>/dev/null || true
    run systemctl reset-failed "vps-gateway-rollback-${tag}.service" 2>/dev/null || true
    run systemctl reset-failed "vps-gateway-rollback-${tag}.timer" 2>/dev/null || true
  fi
  write_file "$BASE_DIR/state/rollback.json" <<'EOF'
{}
EOF
  info "已取消 ${tag} 的回滚定时任务。"
}

validate_sshd() {
  local sshd_bin
  sshd_bin="$(command -v sshd || command -v /usr/sbin/sshd || true)"
  [[ -n "$sshd_bin" ]] || die "未找到 sshd。"
  run "$sshd_bin" -t
  if ((VERBOSE)); then
    "$sshd_bin" -T | grep -Ei '^(port|listenaddress|passwordauthentication|kbdinteractiveauthentication|pubkeyauthentication|permitrootlogin|allowtcpforwarding|x11forwarding|allowagentforwarding|permittunnel) ' || true
  fi
}

reload_ssh() {
  validate_sshd
  if systemctl list-unit-files ssh.service >/dev/null 2>&1; then
    run systemctl reload ssh.service || run systemctl restart ssh.service
  elif systemctl list-unit-files sshd.service >/dev/null 2>&1; then
    run systemctl reload sshd.service || run systemctl restart sshd.service
  else
    die "未找到 ssh.service 或 sshd.service。"
  fi
}

validate_nginx() {
  have nginx || die "未找到 nginx。"
  run nginx -t
}

reload_nginx() {
  validate_nginx
  run systemctl reload nginx
}

lint_generated_nginx_conf() {
  local files=()
  if [[ -d "$NGINX_STREAM_DIR" ]]; then
    while IFS= read -r -d '' f; do files+=("$f"); done < <(find "$NGINX_STREAM_DIR" -type f -name '*.conf' -print0 2>/dev/null || true)
  fi
  if [[ -d "$NGINX_HTTP_DIR" ]]; then
    while IFS= read -r -d '' f; do files+=("$f"); done < <(find "$NGINX_HTTP_DIR" -type f -name '*.conf' -print0 2>/dev/null || true)
  fi
  local has_error=0
  for f in "${files[@]}"; do
    if grep -qE 'listen\[' "$f"; then
      print_error "检测到疑似错误写法 listen[ 在文件 $f 中，应为 listen [。"
      has_error=1
    fi
    if grep -qE '(^|[[:space:]])(listen127|listen0\.|server_name[A-Za-z0-9]|proxy_passhttp|proxy_pass127|ssl_certificate/|ssl_certificate_key/)' "$f"; then
      print_error "文件 $f 中检测到常见指令与参数粘连错误。"
      has_error=1
    fi
    if grep -qE 'ssl_certificate[[:space:]]*;' "$f" || grep -qE 'ssl_certificate_key[[:space:]]*;' "$f"; then
      print_error "文件 $f 中检测到空证书路径配置。"
      has_error=1
    fi
  done
  return "$has_error"
}

cmd_init() {
  require_root
  init_layout
  set_module_state core configured "layout initialized"
  info "已初始化配置目录 ${BASE_DIR} 和日志目录 ${LOG_DIR}。"
}

public_ip() {
  if have curl; then
    curl -fsS --connect-timeout 2 https://api.ipify.org 2>/dev/null || true
  fi
}

check_ports() {
  if have ss; then
    ss -lntup 2>/dev/null || ss -lntu 2>/dev/null || true
  elif have netstat; then
    netstat -lntup 2>/dev/null || true
  fi
}

nginx_has_stream() {
  nginx -V 2>&1 | grep -Eq -- '--with-stream|ngx_stream_module|stream=dynamic'
}

nginx_has_ssl_preread() {
  nginx -V 2>&1 | grep -Eq -- '--with-stream_ssl_preread_module|ngx_stream_ssl_preread_module'
}

detect_cloud_ssh_dropins() {
  find /etc/ssh/sshd_config.d -maxdepth 1 -type f -name '*.conf' 2>/dev/null | while read -r f; do
    if [[ "$f" != "$SSH_DROPIN" ]] && grep -Eiq 'PasswordAuthentication|KbdInteractiveAuthentication|PermitRootLogin|Port|ListenAddress' "$f"; then
      echo "$f"
    fi
  done
}

docker_public_ports() {
  have docker || return 0
  docker ps --format '{{.Names}}|{{.Image}}|{{.Ports}}' 2>/dev/null | grep -E '0\.0\.0\.0:|:::' || true
}

cmd_doctor() {
  init_layout
  local score=100
  echo "VPS Gateway 系统自检 - $(date)"
  echo "版本：$VERSION"
  echo
  detect_os
  echo "系统：${OS_PRETTY_NAME}"
  echo "系统 ID：${OS_ID}"
  echo "版本号：${OS_VERSION_ID}"
  echo "Codename：${OS_CODENAME:-未知}"
  if check_supported_ubuntu; then
    echo "支持范围：是（Ubuntu 20.04 / 22.04 / 24.04）"
  else
    echo "支持范围：未明确支持，可能存在兼容性问题"
    score=$((score-8))
  fi
  echo "当前用户：$(id -un 2>/dev/null || true)，UID=${EUID:-$(id -u)}"
  [[ "${EUID:-$(id -u)}" -eq 0 ]] || { echo "警告：当前不是 root，部分检查可能不完整"; score=$((score-3)); }
  echo "SSH_CONNECTION：${SSH_CONNECTION:-当前不是 SSH 会话}"
  echo "SSH_CLIENT：${SSH_CLIENT:-未知}"
  echo "IPv6 地址："
  ip -6 addr show scope global 2>/dev/null | awk '/inet6/{print "  "$2}' || true
  echo "公网 IPv4：$(public_ip)"
  echo
  echo "当前监听端口："
  check_ports
  echo
  if have nginx; then
    echo "Nginx：已安装 ($(nginx -v 2>&1))"
    nginx_has_stream && echo "Nginx stream：支持" || { echo "Nginx stream：不支持或未知"; score=$((score-10)); }
    nginx_has_ssl_preread && echo "Nginx ssl_preread：支持" || { echo "Nginx ssl_preread：不支持或未知"; score=$((score-10)); }
  else
    echo "Nginx：未安装"; score=$((score-8))
  fi
  echo
  echo "SSH 最终生效配置："
  if have sshd || [[ -x /usr/sbin/sshd ]]; then
    /usr/sbin/sshd -T 2>/dev/null | grep -Ei '^(port|listenaddress|passwordauthentication|kbdinteractiveauthentication|pubkeyauthentication|permitrootlogin)' || true
  else
    echo "未找到 sshd"; score=$((score-10))
  fi
  local cloud_dropins
  cloud_dropins="$(detect_cloud_ssh_dropins || true)"
  if [[ -n "$cloud_dropins" ]]; then
    echo "警告：以下 SSH drop-in 可能覆盖安全配置："
    echo "$cloud_dropins" | sed 's/^/  /'
    score=$((score-6))
  fi
  echo
  if systemctl is-active --quiet ssh.socket 2>/dev/null; then
    echo "警告：ssh.socket 处于启用状态，端口/监听行为可能由 socket activation 驱动。"
    score=$((score-4))
  else
    echo "ssh.socket：未启用或不存在"
  fi
  echo
  if have ufw; then
    echo "UFW："
    ufw status verbose || true
  else
    echo "UFW：未安装"; score=$((score-4))
  fi
  have nft && { echo "nftables："; nft list ruleset 2>/dev/null | head -n 80 || true; }
  have iptables && { echo "iptables INPUT 摘要："; iptables -S INPUT 2>/dev/null || true; }
  echo
  if have docker; then
    echo "Docker：已安装"
    local exposed
    exposed="$(docker_public_ports || true)"
    if [[ -n "$exposed" ]]; then
      echo "警告：检测到 Docker 公网端口映射："
      echo "$exposed" | sed 's/^/  /'
      score=$((score-12))
    else
      echo "Docker 公网映射：未检测到"
    fi
  else
    echo "Docker：未安装"
  fi
  echo
  echo "Vaultwarden 检测："
  detect_vaultwarden || true
  echo "S-UI 检测："
  detect_sui || true
  echo
  [[ "$score" -lt 0 ]] && score=0
  echo "安全评分：${score}/100"
  write_file "$BASE_DIR/state/last-check.json" <<EOF
{"checked_at":"$(date -u '+%Y-%m-%dT%H:%M:%SZ')","score":$score}
EOF
}

cmd_report() { cmd_doctor; }

cmd_install_deps() {
  require_root
  init_layout
  local mode="minimal"
  while (($#)); do
    case "$1" in
      --minimal) mode="minimal"; shift ;;
      --full) mode="full"; shift ;;
      *) die "未知 install-deps 参数：$1" ;;
    esac
  done
  local pkgs=(ca-certificates curl gnupg lsb-release openssh-server nginx-full ufw)
  if [[ "$mode" == "full" ]]; then
    pkgs+=(fail2ban jq socat cron tar gzip dnsutils net-tools)
  fi
  run apt-get update
  run apt-get install -y "${pkgs[@]}"
  set_module_state deps configured "$mode"
  warn "依赖已安装。本命令没有修改 SSH、防火墙、Nginx 路由或服务配置。"
  cmd_doctor
}

cmd_user_create() {
  require_root
  init_layout
  local name=""
  while (($#)); do
    case "$1" in
      --name) name="$2"; shift 2 ;;
      *) die "未知 user-create 参数：$1" ;;
    esac
  done
  [[ "$name" =~ ^[a-z_][a-z0-9_-]*[$]?$ ]] || die "用户名格式无效。"
  if id "$name" >/dev/null 2>&1; then
    info "用户已存在：$name"
  else
    run useradd -m -G sudo -s /bin/bash "$name"
    warn "请为 ${name} 设置强本地控制台密码：passwd ${name}"
  fi
}

ensure_user_ssh_dir() {
  local user="$1"
  local home
  home="$(getent passwd "$user" | cut -d: -f6)"
  [[ -n "$home" && -d "$home" ]] || die "未找到用户 $user 的家目录"
  run mkdir -p "$home/.ssh"
  run chmod 700 "$home/.ssh"
  run touch "$home/.ssh/authorized_keys"
  run chmod 600 "$home/.ssh/authorized_keys"
  run chown -R "$user:$user" "$home/.ssh"
  printf '%s/.ssh/authorized_keys\n' "$home"
}

append_key_unique() {
  local auth="$1" key="$2"
  grep -qxF "$key" "$auth" 2>/dev/null || run sh -c "printf '%s\n' '$key' >> '$auth'"
}

cmd_ssh_import_key() {
  require_root
  init_layout
  local user="" github="" file="" key=""
  while (($#)); do
    case "$1" in
      --user) user="$2"; shift 2 ;;
      --github) github="$2"; shift 2 ;;
      --file) file="$2"; shift 2 ;;
      --key) key="$2"; shift 2 ;;
      *) die "未知 ssh-import-key 参数：$1" ;;
    esac
  done
  [[ -n "$user" ]] || die "必须提供 --user"
  id "$user" >/dev/null 2>&1 || die "用户不存在：$user"
  local auth
  auth="$(ensure_user_ssh_dir "$user")"
  if [[ -n "$github" ]]; then
    have curl || die "需要先安装 curl"
    local keys
    keys="$(curl -fsSL "https://github.com/${github}.keys")"
    [[ -n "$keys" ]] || die "未找到 GitHub 公钥。"
    while IFS= read -r line; do
      [[ "$line" =~ ^ssh- ]] && append_key_unique "$auth" "$line"
    done <<<"$keys"
  elif [[ -n "$file" ]]; then
    [[ -f "$file" ]] || die "未找到公钥文件：$file"
    while IFS= read -r line; do
      [[ "$line" =~ ^ssh- ]] && append_key_unique "$auth" "$line"
    done <"$file"
  elif [[ -n "$key" ]]; then
    [[ "$key" =~ ^ssh- ]] || die "SSH 公钥格式无效。"
    append_key_unique "$auth" "$key"
  else
    die "请使用 --github、--file 或 --key 指定公钥来源。"
  fi
  run chown "$user:$user" "$auth"
  info "已为 $user 导入 SSH 公钥。"
}

authorized_key_count() {
  find /root /home -maxdepth 3 -path '*/.ssh/authorized_keys' -type f 2>/dev/null \
    -exec awk 'NF && $1 ~ /^ssh-/{c++} END{print c+0}' {} + | awk '{s+=$1} END{print s+0}'
}

write_ssh_dropin() {
  local port="${1:-}" internal="${2:-0}"
  local tmp
  tmp="$(mktemp)"
  {
    echo "# Managed by vps-gateway. Do not edit by hand."
    [[ -n "$port" ]] && echo "Port $port"
    if [[ "$internal" == "1" ]]; then
      echo "ListenAddress 127.0.0.1"
      echo "ListenAddress ::1"
    fi
    cat <<'EOF'
PasswordAuthentication no
KbdInteractiveAuthentication no
PubkeyAuthentication yes
PermitRootLogin prohibit-password
PermitEmptyPasswords no
X11Forwarding no
AllowAgentForwarding no
PermitTunnel no
EOF
  } >"$tmp"
  if ((DRY_RUN)); then
    info "预览模式：将写入 $SSH_DROPIN"
    cat "$tmp"
    rm -f "$tmp"
  else
    install -m 600 "$tmp" "$SSH_DROPIN"
    rm -f "$tmp"
  fi
}

cmd_ssh_harden() {
  require_root
  init_layout
  local count
  count="$(authorized_key_count)"
  [[ "$count" -gt 0 ]] || die "未找到可用 SSH 公钥。禁用密码登录前请先导入公钥。"
  local dropins
  dropins="$(detect_cloud_ssh_dropins || true)"
  [[ -z "$dropins" ]] || warn "其他 SSH drop-in 可能覆盖当前设置：$dropins"
  local snap
  snap="$(snapshot_module ssh)"
  write_ssh_dropin "" 0
  
  local sshd_bin
  sshd_bin="$(command -v sshd || command -v /usr/sbin/sshd || true)"
  if [[ -n "$sshd_bin" ]] && ! "$sshd_bin" -t >/dev/null 2>&1; then
    warn "SSHD 配置验证失败。"
    info "正在自动回滚本次修改..."
    restore_module ssh "$snap"
    die "配置验证失败，已自动回滚。"
  fi

  schedule_rollback "ssh" "ssh" "5m" "$snap"
  reload_ssh
  set_module_state ssh configured "hardened"
  /usr/sbin/sshd -T | grep -Ei '^(passwordauthentication|kbdinteractiveauthentication|pubkeyauthentication|permitrootlogin|permitemptypasswords|x11forwarding|allowagentforwarding|permittunnel) ' || true
}

cmd_ssh_internalize() {
  require_root
  init_layout
  local port=""
  while (($#)); do
    case "$1" in
      --port) port="$2"; shift 2 ;;
      *) die "未知 ssh-internalize 参数：$1" ;;
    esac
  done
  [[ "$port" =~ ^[0-9]+$ && "$port" -ge 1 && "$port" -le 65535 ]] || die "--port 必须是 1..65535 之间的数字"
  [[ "$(authorized_key_count)" -gt 0 ]] || die "未找到可用 SSH 公钥。"
  warn "此操作会让 OpenSSH 监听 127.0.0.1:${port}，请保持当前 SSH 会话不要关闭。"
  warn "在验证 SSH over 443 前，不要通过防火墙关闭公网 22。"
  if [[ -n "${SSH_CONNECTION:-}" ]] && ! danger_ack "我已确认有控制台或回滚救援方式" "这是高危 SSH 修改。脚本会安排 systemd 自动回滚，但你仍应具备 VNC/IPMI/救援模式访问能力。"; then
    die "已取消。"
  fi
  local snap
  snap="$(snapshot_module ssh)"
  write_ssh_dropin "$port" 1
  
  local sshd_bin
  sshd_bin="$(command -v sshd || command -v /usr/sbin/sshd || true)"
  if [[ -n "$sshd_bin" ]] && ! "$sshd_bin" -t >/dev/null 2>&1; then
    warn "SSHD 配置验证失败。"
    info "正在自动回滚本次修改..."
    restore_module ssh "$snap"
    die "配置验证失败，已自动回滚。"
  fi

  schedule_rollback "ssh" "ssh" "5m" "$snap"
  if systemctl is-active --quiet ssh.socket 2>/dev/null; then
    warn "ssh.socket 当前处于启用状态。将禁用 socket activation，以便 sshd_config 的 ListenAddress/Port 生效。"
    run systemctl disable --now ssh.socket
  fi
  run systemctl enable --now ssh.service
  reload_ssh
  set_module_state ssh configured "internalized:${port}"
  /usr/sbin/sshd -T | grep -Ei '^(port|listenaddress|passwordauthentication|pubkeyauthentication)' || true
}

cmd_ssh_check() {
  init_layout
  local mark=0
  while (($#)); do
    case "$1" in
      --mark-443-verified) mark=1; shift ;;
      *) die "未知 ssh-check 参数：$1" ;;
    esac
  done
  validate_sshd
  /usr/sbin/sshd -T | grep -Ei '^(port|listenaddress|passwordauthentication|kbdinteractiveauthentication|pubkeyauthentication|permitrootlogin|allowtcpforwarding|x11forwarding|allowagentforwarding|permittunnel) ' || true
  check_ports | grep -E ':(22|2222|443)\b' || true
  if ((mark)); then
    write_file "$BASE_DIR/state/ssh443-verified.env" <<EOF
SSH_OVER_443_VERIFIED=yes
VERIFIED_AT=$(date -u '+%Y-%m-%dT%H:%M:%SZ')
EOF
    info "已标记 SSH over 443 通过人工验证。"
  fi
}

cmd_gateway_install() {
  require_root
  init_layout
  local proto="tcp" udp_backend=""
  while (($#)); do
    case "$1" in
      --proto) proto="$2"; shift 2 ;;
      --udp-backend) udp_backend="$2"; shift 2 ;;
      *) die "未知 gateway-install 参数：$1" ;;
    esac
  done
  [[ "$proto" == "tcp" || "$proto" == "udp" || "$proto" == "both" ]] || die "--proto 只能是 tcp、udp 或 both"
  if [[ "$proto" == "udp" || "$proto" == "both" ]]; then
    [[ -n "$udp_backend" ]] || die "UDP 模式必须提供 --udp-backend"
    backend_is_safe "$udp_backend" || die "UDP 后端必须是安全的本机/内部地址，不能是 0.0.0.0。"
  fi
  have nginx || run apt-get install -y nginx-full
  nginx_has_stream || die "未检测到 Nginx stream 模块。请安装 nginx-full 或对应动态模块。"
  if [[ "$proto" == "tcp" || "$proto" == "both" ]]; then
    nginx_has_ssl_preread || die "未检测到 Nginx ssl_preread 模块。"
  fi
  if [[ -f "$REALITY_CONF_DEFAULT" ]] && grep -Eq 'listen[[:space:]].*443' "$REALITY_CONF_DEFAULT"; then
    die "检测到现有 Reality stream 配置已监听 443：$REALITY_CONF_DEFAULT。请使用 reality-route-* 命令管理路由，不要执行 gateway-install 抢占 443。"
  fi
  local snap
  snap="$(snapshot_module nginx)"
  run mkdir -p "$NGINX_STREAM_DIR"
  ensure_nginx_stream_include
  if [[ "$proto" == "tcp" || "$proto" == "both" ]]; then
    write_file "$NGINX_STREAM_DIR/00-global-map.conf" <<'EOF'
# Managed by vps-gateway.
map $ssl_preread_protocol $vgw_is_tls {
    ""      0;
    default 1;
}

map $ssl_preread_server_name $vgw_tls_backend {
    include /etc/nginx/stream.d/20-sni-routes.conf;
    default 127.0.0.1:8443;
}

map $vgw_is_tls $vgw_final_backend {
    0       127.0.0.1:2222;
    1       $vgw_tls_backend;
}
EOF
    [[ -f "$NGINX_STREAM_DIR/20-sni-routes.conf" ]] || write_file "$NGINX_STREAM_DIR/20-sni-routes.conf" <<'EOF'
# Managed by vps-gateway. Route lines look like:
# example.com 127.0.0.1:8444;
EOF
    write_file "$NGINX_STREAM_DIR/10-ssh-backend.conf" <<'EOF'
# Managed by vps-gateway. SSH backend is 127.0.0.1:2222.
EOF
    write_file "$NGINX_STREAM_DIR/90-gateway.conf" <<'EOF'
# Managed by vps-gateway. Public TCP 443 gateway.
server {
    listen 0.0.0.0:443 reuseport;
    listen [::]:443 reuseport;
    ssl_preread on;
    proxy_connect_timeout 10s;
    proxy_timeout 12h;
    proxy_pass $vgw_final_backend;
}
EOF
  else
    disable_nginx_conf_if_present "$NGINX_STREAM_DIR/90-gateway.conf"
  fi
  if [[ "$proto" == "udp" || "$proto" == "both" ]]; then
    write_file "$NGINX_STREAM_DIR/91-gateway-udp.conf" <<EOF
# Managed by vps-gateway. Public UDP 443 gateway.
server {
    listen 0.0.0.0:443 udp reuseport;
    listen [::]:443 udp reuseport;
    proxy_timeout 12h;
    proxy_responses 0;
    proxy_pass ${udp_backend};
}
EOF
  else
    disable_nginx_conf_if_present "$NGINX_STREAM_DIR/91-gateway-udp.conf"
  fi
  
  if ! lint_generated_nginx_conf || ! nginx -t; then
    warn "Nginx 配置验证失败，网关未启用。"
    info "正在自动回滚本次修改..."
    restore_module nginx "$snap"
    die "配置验证未通过，已回滚。请修复配置后重试。"
  fi

  schedule_rollback "nginx" "nginx" "5m" "$snap"
  reload_nginx
  set_module_state nginx configured "stream gateway installed:${proto}"
  info "网关已启用：${proto}"
}

disable_nginx_conf_if_present() {
  local file="$1" target=""
  [[ -f "$file" ]] || { info "未发现对应配置，已跳过：$file"; return 0; }
  target="${file}.disabled.$(date '+%Y%m%d-%H%M%S')"
  run mv "$file" "$target"
  info "已禁用配置：$file -> $target"
}

ensure_nginx_stream_include() {
  local conf="$NGINX_DIR/nginx.conf"
  [[ -f "$conf" ]] || die "未找到 $conf"
  grep -q 'include /etc/nginx/stream.d/\*.conf;' "$conf" && return 0
  if grep -Eq '^[[:space:]]*stream[[:space:]]*\{' "$conf"; then
    warn "检测到已有 stream 块，但没有 vps-gateway include。请手动加入：include /etc/nginx/stream.d/*.conf;"
    die "为避免误改现有 Nginx stream 配置，已停止自动修改。"
  fi
  local snap
  snap="$(snapshot_module nginx)"
  if ((DRY_RUN)); then
    info "预览模式：将在 $conf 末尾追加 stream include 块"
  else
    local bak="$conf.vps-gateway.bak.$(date '+%Y%m%d-%H%M%S')"
    cp -a "$conf" "$bak"
    cat >>"$conf" <<'EOF'

# Managed by vps-gateway.
stream {
    include /etc/nginx/stream.d/*.conf;
}
EOF
    if ! nginx -t; then
      mv "$bak" "$conf"
      die "自动追加 stream 块导致 Nginx 配置错误并已还原。请手动检查并添加 stream include。"
    fi
  fi
  info "nginx.conf 已纳入 Nginx 快照：$snap"
}

cmd_gateway_enable() { require_root; cmd_gateway_install; }

cmd_gateway_disable() {
  require_root
  init_layout
  local snap
  snap="$(snapshot_module nginx)"
  disable_nginx_conf_if_present "$NGINX_STREAM_DIR/90-gateway.conf"
  disable_nginx_conf_if_present "$NGINX_STREAM_DIR/90-gateway-tcp.conf"
  disable_nginx_conf_if_present "$NGINX_STREAM_DIR/91-gateway-udp.conf"
  
  if ! lint_generated_nginx_conf || ! nginx -t; then
    warn "Nginx 配置验证失败，禁用网关操作导致异常。"
    info "正在自动回滚本次修改..."
    restore_module nginx "$snap"
    die "配置错误已被回滚。"
  fi

  schedule_rollback "nginx" "nginx" "5m" "$snap"
  reload_nginx
  set_module_state nginx disabled "gateway disabled"
}

cmd_gateway_check() {
  init_layout
  have nginx || die "未找到 nginx"
  nginx -V 2>&1 | tr ' ' '\n' | grep -E -- 'stream|ssl_preread' || true
  validate_nginx
  echo "Stream 路由："
  [[ -f "$NGINX_STREAM_DIR/20-sni-routes.conf" ]] && cat "$NGINX_STREAM_DIR/20-sni-routes.conf" || true
  echo
  echo "TCP 443 监听："
  if have ss; then
    ss -lntup 2>/dev/null | grep -E '(:443)\b' || echo "TCP 443：未监听"
  else
    check_ports | grep -E '(:443)\b' || echo "TCP 443：未监听"
  fi
  echo
  echo "UDP 443 监听："
  if have ss; then
    ss -lnuap 2>/dev/null | grep -E '(:443)\b' || echo "UDP 443：未监听"
  else
    echo "UDP 443：无法检测，缺少 ss"
  fi
}

reality_parse_file_arg() {
  local file="$REALITY_CONF_DEFAULT"
  while (($#)); do
    case "$1" in
      --file) file="$2"; shift 2 ;;
      *) shift ;;
    esac
  done
  printf '%s\n' "$file"
}

reality_backend_is_safe() {
  local backend="$1"
  [[ "$backend" =~ ^(127\.0\.0\.1|\[?::1\]?|localhost):[0-9]+$ ]] || return 1
  [[ "$backend" != 0.0.0.0:* && "$backend" != "[::]:"* ]]
}

reality_require_conf() {
  local file="$1"
  [[ -f "$file" ]] || die "未找到 Reality stream 配置：$file"
  grep -q 'map[[:space:]]\+\$ssl_preread_server_name[[:space:]]\+\$backend_reality' "$file" \
    || die "配置文件不像预期的 backend_reality map：$file"
}

cmd_reality_check() {
  init_layout
  local file
  file="$(reality_parse_file_arg "$@")"
  reality_require_conf "$file"
  echo "Reality 配置文件：$file"
  echo
  echo "当前 Reality SNI 路由："
  awk '
    /map[[:space:]]+\$ssl_preread_server_name[[:space:]]+\$backend_reality[[:space:]]*\{/ {inside=1; next}
    inside && /^[[:space:]]*\}/ {inside=0}
    inside && $1 !~ /^#/ && NF >= 2 {print}
  ' "$file"
  echo
  if grep -q '\$ssl_preread_protocol' "$file"; then
    echo "协议分流：已存在"
  else
    warn "未检测到 ssl_preread_protocol 分流。普通 SSH 没有 TLS SNI，会落入 map 的 default 后端。"
  fi
  validate_nginx
}

cmd_reality_route_list() {
  local file
  file="$(reality_parse_file_arg "$@")"
  reality_require_conf "$file"
  awk '
    /map[[:space:]]+\$ssl_preread_server_name[[:space:]]+\$backend_reality[[:space:]]*\{/ {inside=1; next}
    inside && /^[[:space:]]*\}/ {inside=0}
    inside && $1 !~ /^#/ && NF >= 2 {gsub(/;/, "", $2); printf "%-36s %s\n", $1, $2}
  ' "$file"
}

reality_rewrite_route() {
  local file="$1" sni="$2" backend="$3" mode="$4"
  local tmp
  tmp="$(mktemp)"
  set +e
  awk -v sni="$sni" -v backend="$backend" -v mode="$mode" '
    BEGIN {inside=0; changed=0; inserted=0}
    /map[[:space:]]+\$ssl_preread_server_name[[:space:]]+\$backend_reality[[:space:]]*\{/ {inside=1; print; next}
    inside && /^[[:space:]]*\}/ {
      if (mode == "add" && !inserted) {
        printf "    %-34s %s;\n", sni, backend
        inserted=1; changed=1
      }
      inside=0; print; next
    }
    inside && $1 == sni {
      if (mode == "remove") {changed=1; next}
      printf "    %-34s %s;\n", sni, backend
      changed=1; inserted=1
      next
    }
    inside && mode == "add" && $1 == "default" && !inserted {
      printf "    %-34s %s;\n", sni, backend
      inserted=1; changed=1
      print; next
    }
    {print}
    END {
      if (mode == "remove" && changed == 0) exit 3
      if (mode == "add" && changed == 0) exit 4
    }
  ' "$file" >"$tmp"
  local rc=$?
  set -e
  if [[ "$rc" -eq 3 ]]; then
    rm -f "$tmp"
    die "未找到 Reality 路由：$sni"
  elif [[ "$rc" -ne 0 ]]; then
    rm -f "$tmp"
    die "重写 Reality 路由表失败。"
  fi
  if ((DRY_RUN)); then
    info "预览模式：将更新 $file"
    cat "$tmp"
    rm -f "$tmp"
  else
    cp -a "$file" "$file.vps-gateway.bak.$(date '+%Y%m%d-%H%M%S')"
    install -m 644 "$tmp" "$file"
    rm -f "$tmp"
  fi
}

reality_set_default_backend() {
  local file="$1" backend="$2"
  local tmp
  tmp="$(mktemp)"
  set +e
  awk -v backend="$backend" '
    BEGIN {inside=0; changed=0}
    /map[[:space:]]+\$ssl_preread_server_name[[:space:]]+\$backend_reality[[:space:]]*\{/ {inside=1; print; next}
    inside && /^[[:space:]]*\}/ {inside=0; print; next}
    inside && $1 == "default" {
      printf "    %-34s %s;\n", "default", backend
      changed=1
      next
    }
    {print}
    END { if (changed == 0) exit 3 }
  ' "$file" >"$tmp"
  local rc=$?
  set -e
  if [[ "$rc" -ne 0 ]]; then
    rm -f "$tmp"
    die "更新 Reality 默认后端失败。"
  fi
  if ((DRY_RUN)); then
    info "预览模式：将更新 $file"
    cat "$tmp"
    rm -f "$tmp"
  else
    cp -a "$file" "$file.vps-gateway.bak.$(date '+%Y%m%d-%H%M%S')"
    install -m 644 "$tmp" "$file"
    rm -f "$tmp"
  fi
}

cmd_reality_route_add() {
  require_root
  init_layout
  local file="$REALITY_CONF_DEFAULT" sni="" backend=""
  while (($#)); do
    case "$1" in
      --file) file="$2"; shift 2 ;;
      --sni) sni="$2"; shift 2 ;;
      --backend) backend="$2"; shift 2 ;;
      *) die "未知 reality-route-add 参数：$1" ;;
    esac
  done
  valid_sni "$sni" || die "--sni 格式无效"
  reality_backend_is_safe "$backend" || die "Reality 后端必须是本机回环地址，例如 127.0.0.1:6443。"
  reality_require_conf "$file"
  local snap
  snap="$(snapshot_module nginx)"
  reality_rewrite_route "$file" "$sni" "$backend" "add"
  
  if ! lint_generated_nginx_conf || ! nginx -t; then
    warn "Nginx 配置测试失败，Reality 路由未启用。"
    info "正在自动回滚本次修改..."
    restore_module nginx "$snap"
    die "配置错误已被回滚。"
  fi

  schedule_rollback "nginx" "nginx" "5m" "$snap"
  reload_nginx
  info "Reality 路由已设置：$sni -> $backend"
}

cmd_reality_route_remove() {
  require_root
  init_layout
  local file="$REALITY_CONF_DEFAULT" sni=""
  while (($#)); do
    case "$1" in
      --file) file="$2"; shift 2 ;;
      --sni) sni="$2"; shift 2 ;;
      *) die "未知 reality-route-remove 参数：$1" ;;
    esac
  done
  valid_sni "$sni" || die "--sni 格式无效"
  reality_require_conf "$file"
  confirm_prompt "确认从 ${file} 删除 Reality SNI 路由 ${sni} 吗？" || die "已取消。"
  local snap
  snap="$(snapshot_module nginx)"
  reality_rewrite_route "$file" "$sni" "" "remove"
  
  if ! lint_generated_nginx_conf || ! nginx -t; then
    warn "Nginx 配置测试失败，删除操作导致异常。"
    info "正在自动回滚本次修改..."
    restore_module nginx "$snap"
    die "配置错误已被回滚。"
  fi

  schedule_rollback "nginx" "nginx" "5m" "$snap"
  reload_nginx
  info "Reality 路由已删除：$sni"
}

cmd_reality_route_set_default() {
  require_root
  init_layout
  local file="$REALITY_CONF_DEFAULT" backend=""
  while (($#)); do
    case "$1" in
      --file) file="$2"; shift 2 ;;
      --backend) backend="$2"; shift 2 ;;
      *) die "未知 reality-route-set-default 参数：$1" ;;
    esac
  done
  reality_backend_is_safe "$backend" || die "默认后端必须是本机回环地址。"
  reality_require_conf "$file"
  local snap
  snap="$(snapshot_module nginx)"
  reality_set_default_backend "$file" "$backend"
  
  if ! lint_generated_nginx_conf || ! nginx -t; then
    warn "Nginx 配置测试失败，修改默认后端导致异常。"
    info "正在自动回滚本次修改..."
    restore_module nginx "$snap"
    die "配置错误已被回滚。"
  fi

  schedule_rollback "nginx" "nginx" "5m" "$snap"
  reload_nginx
  info "Reality 默认后端已设置为 $backend"
}

ensure_reality_conf_interactive() {
  local current_file="$1" candidate=""
  ensure_nginx_interactive || return 1
  if [[ -f "$current_file" ]]; then
    REALITY_SELECTED_FILE="$current_file"
    return 0
  fi

  while true; do
    print_banner "Reality 配置缺失"
    printf '未找到 Reality stream 配置文件：%s\n\n' "$current_file"
    print_menu_item 1 "输入 Reality 配置文件路径"
    print_menu_item 2 "返回上一级"
    printf '\n'
    ui_line
    if ! read -r -p "请选择操作 [1-2]: " c; then
      return 1
    fi
    c="${c//$'\r'/}"
    case "$c" in
      1)
        read -r -p "请输入 Reality 配置文件路径: " candidate
        candidate="${candidate//$'\r'/}"
        if [[ -z "$candidate" ]]; then
          print_error "配置文件路径不能为空。"
          pause_return
          continue
        fi
        if [[ -f "$candidate" ]]; then
          REALITY_SELECTED_FILE="$candidate"
          return 0
        fi
        print_error "文件仍不存在：$candidate"
        pause_return
        ;;
      2) return 1 ;;
      *) print_warning "无效选项，请输入 1-2 之间的数字。" ;;
    esac
  done
}

show_reality_menu() {
  local file="$REALITY_CONF_DEFAULT"
  REALITY_SELECTED_FILE="$file"
  while true; do
    print_banner "Reality SNI 路由管理"
    printf '当前配置：%s\n\n' "$file"
    print_menu_item 1 "检查 Reality stream 配置"
    print_menu_item 2 "查看 Reality SNI 路由"
    print_menu_item 3 "添加 / 更新 Reality SNI 路由"
    print_menu_item 4 "删除 Reality SNI 路由"
    print_menu_item 5 "修改默认 Reality 后端"
    print_menu_item 6 "切换配置文件"
    print_menu_item 7 "返回主菜单"
    printf '\n'
    ui_line
    if ! read -r -p "请选择操作 [1-7]: " c; then
      echo "已退出 Reality SNI 路由管理。"
      return 0
    fi
    c="${c//$'\r'/}"
    case "$c" in
      1)
        ensure_reality_conf_interactive "$file" || continue
        file="$REALITY_SELECTED_FILE"
        run_menu_action cmd_reality_check --file "$file"
        ;;
      2)
        ensure_reality_conf_interactive "$file" || continue
        file="$REALITY_SELECTED_FILE"
        run_menu_action cmd_reality_route_list --file "$file"
        ;;
      3)
        ensure_reality_conf_interactive "$file" || continue
        file="$REALITY_SELECTED_FILE"
        local sni="" backend=""
        read -r -p "请输入 SNI 域名: " sni
        read -r -p "请输入后端地址，例如 127.0.0.1:6443: " backend
        run_menu_action cmd_reality_route_add --file "$file" --sni "$sni" --backend "$backend"
        ;;
      4)
        ensure_reality_conf_interactive "$file" || continue
        file="$REALITY_SELECTED_FILE"
        local sni=""
        read -r -p "请输入要删除的 SNI 域名: " sni
        run_menu_action cmd_reality_route_remove --file "$file" --sni "$sni"
        ;;
      5)
        ensure_reality_conf_interactive "$file" || continue
        file="$REALITY_SELECTED_FILE"
        local backend=""
        read -r -p "请输入默认后端，例如 127.0.0.1:2443: " backend
        run_menu_action cmd_reality_route_set_default --file "$file" --backend "$backend"
        ;;
      6)
        read -r -p "请输入 Reality 配置文件路径: " file
        file="${file//$'\r'/}"
        [[ -n "$file" ]] || file="$REALITY_CONF_DEFAULT"
        ;;
      7) return 0 ;;
      *) print_warning "无效选项，请输入 1-7 之间的数字。" ;;
    esac
  done
}

cmd_reality_menu() { show_reality_menu "$@"; }

valid_sni() { [[ "$1" =~ ^(\*\.)?[A-Za-z0-9.-]+$ && "$1" == *.* ]]; }
valid_port() { [[ "$1" =~ ^[0-9]+$ && "$1" -ge 1 && "$1" -le 65535 ]]; }
backend_is_safe() {
  local backend="$1"
  [[ "$backend" =~ ^(127\.0\.0\.1|\[?::1\]?|localhost|[A-Za-z0-9_.-]+):[0-9]+$ ]] || return 1
  [[ "$backend" != 0.0.0.0:* && "$backend" != "[::]:"* ]]
}

route_json_path() { printf '%s/routes.d/%s.json' "$BASE_DIR" "$1"; }
inner_conf_path() { printf '%s/%s.inner.conf' "$NGINX_HTTP_DIR" "$1"; }
udp_route_conf_path() { printf '%s/udp-%s.conf' "$NGINX_STREAM_DIR" "$1"; }

safe_route_name() {
  local name="$1"
  printf '%s' "$name" | tr -c 'A-Za-z0-9_.-' '_'
}

route_line_exists() {
  local sni="$1"
  [[ -f "$NGINX_STREAM_DIR/20-sni-routes.conf" ]] && grep -Eq "^[[:space:]]*${sni//./\\.}[[:space:]]+" "$NGINX_STREAM_DIR/20-sni-routes.conf"
}

inner_port_conflict() {
  local port="$1" sni="${2:-}"
  grep -R "listen 127.0.0.1:${port} ssl" "$NGINX_HTTP_DIR" "$BASE_DIR/routes.d" 2>/dev/null | grep -v "$sni" || true
}

rebuild_routes_index() {
  local out="$BASE_DIR/state/routes.json"
  if have jq; then
    jq -s '.' "$BASE_DIR"/routes.d/*.json >"$out" 2>/dev/null || echo '[]' >"$out"
  else
    {
      echo "["
      local first=1 f
      for f in "$BASE_DIR"/routes.d/*.json; do
        [[ -f "$f" ]] || continue
        ((first)) || echo ","
        first=0
        cat "$f"
      done
      echo "]"
    } >"$out"
  fi
  chmod 600 "$out" 2>/dev/null || true
}

write_route_state() {
  local sni="$1" inner_port="$2" backend="$3" type="$4" cert="$5" key="$6" enabled="$7" status="$8"
  write_file "$(route_json_path "$sni")" <<EOF
{"sni":"$sni","inner_port":$inner_port,"backend":"$backend","type":"$type","cert":"$cert","key":"$key","enabled":$enabled,"status":"$status","updated_at":"$(date -u '+%Y-%m-%dT%H:%M:%SZ')"}
EOF
  rebuild_routes_index
}

write_udp_route_state() {
  local name="$1" listen_port="$2" backend="$3"
  write_file "$(route_json_path "udp-$name")" <<EOF
{"protocol":"udp","name":"$name","listen_port":$listen_port,"backend":"$backend","enabled":true,"status":"enabled","updated_at":"$(date -u '+%Y-%m-%dT%H:%M:%SZ')"}
EOF
  rebuild_routes_index
}

cmd_udp_route_add() {
  require_root
  init_layout
  local name="" listen_port="" backend=""
  while (($#)); do
    case "$1" in
      --name) name="$2"; shift 2 ;;
      --listen-port) listen_port="$2"; shift 2 ;;
      --backend) backend="$2"; shift 2 ;;
      *) die "未知 udp-route-add 参数：$1" ;;
    esac
  done
  [[ -n "$name" ]] || die "必须提供 --name"
  name="$(safe_route_name "$name")"
  valid_port "$listen_port" || die "--listen-port 格式无效"
  backend_is_safe "$backend" || die "UDP 后端必须是回环/内部地址，不能配置为 0.0.0.0。"
  have nginx || die "未找到 nginx"
  nginx_has_stream || die "未检测到 Nginx stream 模块。"
  local snap
  snap="$(snapshot_module routes)"
  run mkdir -p "$NGINX_STREAM_DIR"
  ensure_nginx_stream_include
  write_file "$(udp_route_conf_path "$name")" <<EOF
# Managed by vps-gateway. UDP stream route.
server {
    listen 127.0.0.1:${listen_port} udp reuseport;
    listen [::1]:${listen_port} udp reuseport;
    proxy_timeout 12h;
    proxy_responses 0;
    proxy_pass ${backend};
}
EOF
  
  if ! lint_generated_nginx_conf || ! nginx -t; then
    warn "Nginx 配置验证失败，UDP 路由未启用。"
    info "正在自动回滚本次修改..."
    restore_module routes "$snap"
    die "配置验证未通过，已自动回滚。请修复配置后重试。"
  fi

  schedule_rollback "routes" "routes" "5m" "$snap"
  reload_nginx
  write_udp_route_state "$name" "$listen_port" "$backend"
  info "UDP 路由已启用：127.0.0.1:${listen_port}/udp -> ${backend}"
}

generate_inner_nginx_conf() {
  local sni="$1" inner_port="$2" backend="$3" type="$4" cert="$5" key="$6"
local proxy_host="\$host"
  local access_log="off"
  [[ "$type" != "vaultwarden" ]] && access_log="/var/log/nginx/${sni}.access.log"
  write_file "$(inner_conf_path "$sni")" <<EOF
# Managed by vps-gateway.
server {
    listen 127.0.0.1:${inner_port} ssl;
    listen [::1]:${inner_port} ssl;
    http2 on;
    server_name ${sni};

    ssl_certificate ${cert};
    ssl_certificate_key ${key};
    ssl_protocols TLSv1.2 TLSv1.3;

    access_log ${access_log};
    error_log /var/log/nginx/${sni}.error.log warn;

    location / {
        proxy_pass http://${backend};
        proxy_http_version 1.1;
        proxy_set_header Host ${proxy_host};
        proxy_set_header X-Forwarded-Host \$host;
        proxy_set_header X-Forwarded-Port 443;
        proxy_set_header X-Forwarded-Ssl on;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \$scheme;
        proxy_set_header Upgrade \$http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_read_timeout 3600;
    }
}
EOF
}

add_stream_route_line() {
  local sni="$1" inner_port="$2"
  run mkdir -p "$NGINX_STREAM_DIR"
  [[ -f "$NGINX_STREAM_DIR/20-sni-routes.conf" ]] || write_file "$NGINX_STREAM_DIR/20-sni-routes.conf" <<'EOF'
# Managed by vps-gateway.
EOF
  if route_line_exists "$sni"; then
    run sed -i.bak -E "s|^[[:space:]]*${sni//./\\.}[[:space:]].*|    ${sni} 127.0.0.1:${inner_port};|" "$NGINX_STREAM_DIR/20-sni-routes.conf"
  else
    run sh -c "printf '    %-34s 127.0.0.1:%s;\n' '$sni' '$inner_port' >> '$NGINX_STREAM_DIR/20-sni-routes.conf'"
  fi
}

add_stream_route_backend_line() {
  local sni="$1" backend="$2"
  run mkdir -p "$NGINX_STREAM_DIR"
  [[ -f "$NGINX_STREAM_DIR/20-sni-routes.conf" ]] || write_file "$NGINX_STREAM_DIR/20-sni-routes.conf" <<'EOF'
# Managed by vps-gateway.
EOF
  if route_line_exists "$sni"; then
    run sed -i.bak -E "s|^[[:space:]]*${sni//./\\.}[[:space:]].*|    ${sni} ${backend};|" "$NGINX_STREAM_DIR/20-sni-routes.conf"
  else
    run sh -c "printf '    %-34s %s;\n' '$sni' '$backend' >> '$NGINX_STREAM_DIR/20-sni-routes.conf'"
  fi
}

remove_stream_route_line() {
  local sni="$1"
  [[ -f "$NGINX_STREAM_DIR/20-sni-routes.conf" ]] || return 0
  run sed -i.bak -E "/^[[:space:]]*${sni//./\\.}[[:space:]]+/d" "$NGINX_STREAM_DIR/20-sni-routes.conf"
}

cmd_route_add() {
  require_root
  init_layout
  local sni="" inner_port="" backend="" type="generic" cert_domain="" cert="" key=""
  while (($#)); do
    case "$1" in
      --sni) sni="$2"; shift 2 ;;
      --inner-port) inner_port="$2"; shift 2 ;;
      --backend) backend="$2"; shift 2 ;;
      --type) type="$2"; shift 2 ;;
      --cert-domain) cert_domain="$2"; shift 2 ;;
      --cert) cert="$2"; shift 2 ;;
      --key) key="$2"; shift 2 ;;
      *) die "未知 route-add 参数：$1" ;;
    esac
  done
  valid_sni "$sni" || die "--sni 格式无效"
  
  if [[ "$type" != "tcp-pass-through" ]]; then
    valid_port "$inner_port" || die "--inner-port 格式无效"
    [[ -z "$(inner_port_conflict "$inner_port" "$sni")" ]] || die "内层端口冲突：$inner_port"
  else
    inner_port="0"
  fi
  
  backend_is_safe "$backend" || die "后端必须是回环/内部地址，不能配置为 0.0.0.0。"
  
  if [[ -z "$cert" && -z "$key" && "$type" != "tcp-pass-through" ]]; then
    local d="${cert_domain:-$sni}"
    cert="$BASE_DIR/certs/$d/fullchain.pem"
    key="$BASE_DIR/certs/$d/privkey.pem"
  fi
  
  if [[ "$type" == "tcp-pass-through" ]]; then
    cert=""
    key=""
  elif [[ ! -f "$cert" || ! -f "$key" ]]; then
    warn "证书文件缺失。将只创建 pending_cert 状态，不启用该路由。"
    write_route_state "$sni" "$inner_port" "$backend" "$type" "$cert" "$key" "false" "pending_cert"
    return 0
  fi
  
  local snap
  snap="$(snapshot_module routes)"
  
  if [[ "$type" == "tcp-pass-through" ]]; then
    add_stream_route_backend_line "$sni" "$backend"
  else
    generate_inner_nginx_conf "$sni" "$inner_port" "$backend" "$type" "$cert" "$key"
    add_stream_route_line "$sni" "$inner_port"
  fi
  
  if ! lint_generated_nginx_conf || ! nginx -t; then
    warn "Nginx 配置验证失败，路由未启用。"
    info "正在自动回滚本次修改..."
    restore_module routes "$snap"
    die "配置验证未通过，已自动回滚。请修复配置后重试。"
  fi
  
  schedule_rollback "routes" "routes" "5m" "$snap"
  reload_nginx
  write_route_state "$sni" "$inner_port" "$backend" "$type" "$cert" "$key" "true" "enabled"
  
  if [[ "$type" == "tcp-pass-through" ]]; then
    info "TCP 透传路由已启用：${sni} -> ${backend}"
  else
    info "路由已启用：${sni} -> 127.0.0.1:${inner_port} -> ${backend}"
  fi
}

cmd_route_remove() {
  require_root
  init_layout
  local sni=""
  while (($#)); do case "$1" in --sni) sni="$2"; shift 2 ;; *) die "未知 route-remove 参数：$1" ;; esac; done
  valid_sni "$sni" || die "--sni 格式无效"
  confirm_prompt "确认删除路由 ${sni} 吗？" || die "已取消。"
  local snap
  snap="$(snapshot_module routes)"
  remove_stream_route_line "$sni"
  [[ -f "$(inner_conf_path "$sni")" ]] && run rm -f "$(inner_conf_path "$sni")"
  [[ -f "$(route_json_path "$sni")" ]] && run rm -f "$(route_json_path "$sni")"
  rebuild_routes_index
  
  if ! lint_generated_nginx_conf || ! nginx -t; then
    warn "Nginx 配置验证失败，删除操作导致异常。"
    info "正在自动回滚本次修改..."
    restore_module routes "$snap"
    die "配置验证未通过，已自动回滚。"
  fi

  schedule_rollback "routes" "routes" "5m" "$snap"
  reload_nginx
}

cmd_route_list() {
  init_layout
  rebuild_routes_index
  cat "$BASE_DIR/state/routes.json"
  local f
  for f in "$NGINX_STREAM_DIR"/udp-*.conf; do
    [[ -f "$f" ]] || continue
    printf 'UDP 配置文件：%s\n' "$f"
  done
}

cmd_route_disable() {
  require_root
  local sni=""
  while (($#)); do case "$1" in --sni) sni="$2"; shift 2 ;; *) die "未知 route-disable 参数：$1" ;; esac; done
  valid_sni "$sni" || die "--sni 格式无效"
  local snap
  snap="$(snapshot_module routes)"
  remove_stream_route_line "$sni"
  [[ -f "$(inner_conf_path "$sni")" ]] && run mv "$(inner_conf_path "$sni")" "$(inner_conf_path "$sni").disabled"
  
  if ! lint_generated_nginx_conf || ! nginx -t; then
    warn "Nginx 配置验证失败，禁用操作导致异常。"
    info "正在自动回滚本次修改..."
    restore_module routes "$snap"
    die "配置验证未通过，已自动回滚。"
  fi

  schedule_rollback "routes" "routes" "5m" "$snap"
  reload_nginx
  info "路由已禁用：$sni"
}

cmd_route_enable() {
  require_root
  local sni=""
  while (($#)); do case "$1" in --sni) sni="$2"; shift 2 ;; *) die "未知 route-enable 参数：$1" ;; esac; done
  valid_sni "$sni" || die "--sni 格式无效"
  local json
  json="$(route_json_path "$sni")"
  [[ -f "$json" ]] || die "未找到路由状态：$sni"
  local inner_port backend type cert key
  if have jq; then
    inner_port="$(jq -r .inner_port "$json")"; backend="$(jq -r .backend "$json")"; type="$(jq -r .type "$json")"; cert="$(jq -r .cert "$json")"; key="$(jq -r .key "$json")"
  else
    inner_port="$(grep -o '"inner_port":[0-9]*' "$json" | cut -d: -f2)"
    backend="$(grep -o '"backend":"[^"]*' "$json" | cut -d\" -f4)"
    type="$(grep -o '"type":"[^"]*' "$json" | cut -d\" -f4)"
    cert="$(grep -o '"cert":"[^"]*' "$json" | cut -d\" -f4)"
    key="$(grep -o '"key":"[^"]*' "$json" | cut -d\" -f4)"
  fi
  [[ "$type" == "tcp-pass-through" || ( -f "$cert" && -f "$key" ) ]] || die "$sni 缺少证书文件"
  
  local snap
  snap="$(snapshot_module routes)"
  
  if [[ "$type" == "tcp-pass-through" ]]; then
    add_stream_route_backend_line "$sni" "$backend"
  else
    [[ -f "$(inner_conf_path "$sni").disabled" ]] && run mv "$(inner_conf_path "$sni").disabled" "$(inner_conf_path "$sni")"
    if [[ ! -f "$(inner_conf_path "$sni")" ]]; then
      generate_inner_nginx_conf "$sni" "$inner_port" "$backend" "$type" "$cert" "$key"
    fi
    add_stream_route_line "$sni" "$inner_port"
  fi
  
  if ! lint_generated_nginx_conf || ! nginx -t; then
    warn "Nginx 配置验证失败，启用操作导致异常。"
    info "正在自动回滚本次修改..."
    restore_module routes "$snap"
    die "配置验证未通过，已自动回滚。"
  fi

  schedule_rollback "routes" "routes" "5m" "$snap"
  reload_nginx
  write_route_state "$sni" "$inner_port" "$backend" "$type" "$cert" "$key" "true" "enabled"
  info "路由已启用：$sni"
}

cmd_route_check() {
  local sni=""
  while (($#)); do case "$1" in --sni) sni="$2"; shift 2 ;; *) die "未知 route-check 参数：$1" ;; esac; done
  if ! valid_sni "$sni"; then
    local udp_name udp_name_alt udp_json udp_conf udp_json_alt udp_conf_alt
    udp_name="$(safe_route_name "$sni")"
    udp_name_alt="${udp_name#udp-}"
    udp_json="$(route_json_path "udp-$udp_name")"
    udp_conf="$(udp_route_conf_path "$udp_name")"
    udp_json_alt="$(route_json_path "udp-$udp_name_alt")"
    udp_conf_alt="$(udp_route_conf_path "$udp_name_alt")"
    if [[ -f "$udp_json" || -f "$udp_conf" || -f "$udp_json_alt" || -f "$udp_conf_alt" ]]; then
      [[ -f "$udp_json" ]] && cat "$udp_json"
      [[ -f "$udp_conf" ]] && cat "$udp_conf"
      [[ -f "$udp_json_alt" ]] && cat "$udp_json_alt"
      [[ -f "$udp_conf_alt" ]] && cat "$udp_conf_alt"
      validate_nginx
      return 0
    fi
    die "--sni 格式无效，且未找到同名 UDP 路由"
  fi
  [[ -f "$(route_json_path "$sni")" ]] && cat "$(route_json_path "$sni")" || warn "未找到 $sni 的状态文件"
  grep -R "$sni" "$NGINX_STREAM_DIR" "$NGINX_HTTP_DIR" 2>/dev/null || true
  validate_nginx
}

