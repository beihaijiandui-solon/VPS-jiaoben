        ensure_nginx_interactive || continue
        if [[ ! -x /root/.acme.sh/acme.sh ]]; then
          print_warning "未检测到 acme.sh，签发证书前需要先安装。"
          if confirm_prompt "是否现在安装 acme.sh？"; then
            run_menu_action cmd_cert_install_acme
          else
            pause_return
            continue
          fi
        fi
        local domain="" email=""
        if ! domain="$(prompt_required "请输入证书域名: ")"; then pause_return; continue; fi
        if ! email="$(prompt_required "请输入邮箱: ")"; then pause_return; continue; fi
        run_menu_action cmd_cert_issue --domain "$domain" --email "$email"
        ;;
      3)
        local domain="" cert="" key=""
        if ! domain="$(prompt_required "请输入证书域名: ")"; then pause_return; continue; fi
        if ! cert="$(prompt_required "请输入 fullchain.pem 路径: ")"; then pause_return; continue; fi
        if ! key="$(prompt_required "请输入 privkey.pem 路径: ")"; then pause_return; continue; fi
        run_menu_action cmd_cert_import --domain "$domain" --cert "$cert" --key "$key"
        ;;
      4)
        ensure_command_interactive openssl openssl || continue
        run_menu_action cmd_cert_status
        ;;
      5) run_menu_action cmd_cert_list ;;
      6)
        ensure_nginx_interactive || continue
        if [[ ! -x /root/.acme.sh/acme.sh ]]; then
          print_warning "未检测到 acme.sh，请先安装 acme.sh。"
          if confirm_prompt "是否现在安装 acme.sh？"; then
            ensure_curl_interactive || continue
            run_menu_action cmd_cert_install_acme
          else
            pause_return
            continue
          fi
        fi
        if confirm_prompt "确认执行证书续期吗？"; then
          run_menu_action cmd_cert_renew
        else
          print_info "已取消证书续期。"
          pause_return
        fi
        ;;
      7)
        local domain=""
        if ! domain="$(prompt_required "请输入要删除证书的域名: ")"; then pause_return; continue; fi
        if confirm_prompt "确认删除 ${domain} 的证书吗？"; then
          run_menu_action cmd_cert_remove --domain "$domain"
        else
          print_info "已取消删除证书。"
          pause_return
        fi
        ;;
      8) run_menu_action cmd_cert_find ;;
      9) return 0 ;;
      *) print_warning "无效选项，请输入 1-9 之间的数字。" ;;
    esac
  done
}

