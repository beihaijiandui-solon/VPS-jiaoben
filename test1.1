cmd_cert_install_acme() {
  require_root
  init_layout
  have curl || run apt-get install -y curl socat cron
  if [[ ! -x /root/.acme.sh/acme.sh ]]; then
    run sh -c 'curl -fsSL https://get.acme.sh | sh'
  fi
  set_module_state cert configured "acme.sh installed"
}

cmd_cert_set_cloudflare() {
  require_root
  init_layout
  local token=""
  read -rsp "请输入 Cloudflare DNS API Token（不要使用 Global API Key）: " token
  echo
  [[ -n "$token" ]] || die "Token 不能为空。"
  write_file "$BASE_DIR/secrets/cloudflare.env" <<EOF
CF_Token='$token'
EOF
  run chmod 600 "$BASE_DIR/secrets/cloudflare.env"
  warn "请使用最小权限 Token：仅指定 Zone 的 DNS Edit 权限。"
}

cmd_cert_issue() {
  require_root
  init_layout
  local domain="" email=""
  while (($#)); do
    case "$1" in
      --domain) domain="$2"; shift 2 ;;
      --email) email="$2"; shift 2 ;;
      *) die "未知 cert-issue 参数：$1" ;;
    esac
  done
  valid_sni "$domain" || die "域名格式无效"
  [[ -n "$email" ]] || die "必须提供 --email"
  [[ -f "$BASE_DIR/secrets/cloudflare.env" ]] || die "请先执行 cert-set-cloudflare。"
  cmd_cert_install_acme
  # shellcheck disable=SC1090
  . "$BASE_DIR/secrets/cloudflare.env"
  export CF_Token
  local cert_dir="$BASE_DIR/certs/$domain"
  run mkdir -p "$cert_dir"
  local snap
  snap="$(snapshot_module certs)"
  run /root/.acme.sh/acme.sh --register-account -m "$email" || true
  run /root/.acme.sh/acme.sh --issue --dns dns_cf -d "$domain" --keylength ec-256
  run /root/.acme.sh/acme.sh --install-cert -d "$domain" --ecc \
    --fullchain-file "$cert_dir/fullchain.pem" \
    --key-file "$cert_dir/privkey.pem" \
    --reloadcmd "systemctl reload nginx"
  run chmod 600 "$cert_dir/privkey.pem"
  write_file "$cert_dir/meta.json" <<EOF
{"domain":"$domain","source":"acme.sh","key_type":"ec-256","updated_at":"$(date -u '+%Y-%m-%dT%H:%M:%SZ')"}
EOF
  validate_nginx || true
  schedule_rollback "certs" "certs" "10m" "$snap"
  have systemctl && systemctl reload nginx 2>/dev/null || true
}

cmd_cert_import() {
  require_root
  init_layout
  local domain="" cert="" key=""
  while (($#)); do
    case "$1" in
      --domain) domain="$2"; shift 2 ;;
      --cert) cert="$2"; shift 2 ;;
      --key) key="$2"; shift 2 ;;
      *) die "未知 cert-import 参数：$1" ;;
    esac
  done
  valid_sni "$domain" || die "域名格式无效"
  [[ -f "$cert" && -f "$key" ]] || die "未找到证书或私钥文件。"
  local dest="$BASE_DIR/certs/$domain"
  local snap
  snap="$(snapshot_module certs)"
  run mkdir -p "$dest"
  run install -m 600 "$cert" "$dest/fullchain.pem"
  run install -m 600 "$key" "$dest/privkey.pem"
  write_file "$dest/meta.json" <<EOF
{"domain":"$domain","source":"import","updated_at":"$(date -u '+%Y-%m-%dT%H:%M:%SZ')"}
EOF
  schedule_rollback "certs" "certs" "10m" "$snap"
}

cmd_cert_list() { find "$BASE_DIR/certs" -mindepth 1 -maxdepth 1 -type d -printf '%f\n' 2>/dev/null || true; }
cmd_cert_status() {
  local d
  for d in "$BASE_DIR"/certs/*; do
    [[ -f "$d/fullchain.pem" ]] || continue
    echo "== $(basename "$d") =="
    openssl x509 -in "$d/fullchain.pem" -noout -subject -issuer -dates 2>/dev/null || true
    stat -c 'privkey mode: %a %n' "$d/privkey.pem" 2>/dev/null || true
  done
}
cmd_cert_renew() {
  require_root
  [[ -x /root/.acme.sh/acme.sh ]] || die "尚未安装 acme.sh"
  run /root/.acme.sh/acme.sh --cron --home /root/.acme.sh
  have systemctl && run systemctl reload nginx || true
}
cmd_cert_remove() {
  require_root
  local domain=""
  while (($#)); do case "$1" in --domain) domain="$2"; shift 2 ;; *) die "未知 cert-remove 参数：$1" ;; esac; done
  valid_sni "$domain" || die "域名格式无效"
  grep -R "\"cert\":\"$BASE_DIR/certs/$domain/" "$BASE_DIR/routes.d" >/dev/null 2>&1 && die "证书仍被路由引用，不能删除。"
  confirm_prompt "确认删除 $domain 的证书文件吗？" || die "已取消。"
  snapshot_module certs >/dev/null
  run rm -rf "$BASE_DIR/certs/$domain"
}

cmd_cert_find() {
  print_section "查找常见证书路径"
  print_info "正在轻量扫描常见证书目录..."
  local search_dirs=(
    "/etc/vps-gateway/certs"
    "/etc/letsencrypt/live"
    "/root/.acme.sh"
    "/etc/ssl"
    "/etc/nginx/certs"
    "/opt"
  )
  
  local found=0
  for dir in "${search_dirs[@]}"; do
    if [[ -d "$dir" ]]; then
      while IFS= read -r file; do
        [[ -z "$file" ]] && continue
        found=1
        stat -c '%A  %U:%G  %n' "$file" 2>/dev/null || ls -l "$file" | awk '{print $1"  "$3":"$4"  "$9}'
      done < <(find "$dir" -maxdepth 4 -type f \( -iname "fullchain.pem" -o -iname "privkey.pem" -o -iname "cert.pem" -o -iname "chain.pem" -o -iname "*.cer" -o -iname "*.key" -o -iname "*.crt" \) 2>/dev/null)
    fi
  done
  
  if ((found)); then
    print_info "扫描完成。如果发现成对的 fullchain / privkey，可以在路由配置【手动指定证书文件路径】时直接复制使用。"
  else
    print_warning "未在常见目录中找到证书文件。"
  fi
}

ssh443_verified() { [[ -f "$BASE_DIR/state/ssh443-verified.env" ]] && grep -q 'SSH_OVER_443_VERIFIED=yes' "$BASE_DIR/state/ssh443-verified.env"; }

cmd_firewall_check() {
  have ufw && ufw status verbose || warn "未安装 ufw"
  have ufw && ufw status numbered || true
  have nft && nft list ruleset 2>/dev/null | head -n 120 || true
  have iptables && { echo "iptables INPUT 摘要："; iptables -S INPUT 2>/dev/null || true; }
  have ip6tables && { echo "ip6tables INPUT 摘要："; ip6tables -S INPUT 2>/dev/null || true; }
  echo "Docker 公网端口："
  docker_public_ports || true
}

cmd_firewall_stage() {
  require_root
  init_layout
  have ufw || run apt-get install -y ufw
  docker_public_ports >/tmp/vps-gateway-docker-exposure.$$ 2>/dev/null || true
  if [[ -s /tmp/vps-gateway-docker-exposure.$$ ]]; then
    warn "Docker 公网端口映射可能绕过 UFW。严格收紧防火墙前请先检查 docker-check-exposure。"
    cat /tmp/vps-gateway-docker-exposure.$$
  fi
  rm -f /tmp/vps-gateway-docker-exposure.$$ || true
  if ! ssh443_verified; then
    warn "尚未标记 SSH over 443 已验证。"
    warn "请打开一个新终端验证：ssh -p 443 USER@IP"
    danger_ack "我已验证 SSH over 443" "firewall-stage 将只允许 TCP/UDP 443 入站，可能关闭公网 22。" || die "已取消。"
    cmd_ssh_check --mark-443-verified
  fi
  local snap
  snap="$(snapshot_module firewall)"
  schedule_rollback "firewall" "firewall" "5m" "$snap"
  run ufw --force reset
  run ufw default deny incoming
  run ufw default allow outgoing
  run ufw allow in 443/tcp comment "vps-gateway public tcp entry"
  run ufw allow in 443/udp comment "vps-gateway public udp entry"
  run ufw --force enable
  set_module_state firewall configured "only tcp/udp 443 staged"
  info "已允许 TCP 443 和 UDP 443 入站。"
  warn "云厂商安全组也需要同步设置为只允许 TCP/UDP 443 入站。"
}

cmd_firewall_confirm() { cancel_rollback firewall; info "防火墙变更已确认。"; }
cmd_firewall_open() {
  require_root
  local port="" proto="tcp"
  while (($#)); do case "$1" in --port) port="$2"; shift 2 ;; --proto) proto="$2"; shift 2 ;; *) die "未知 firewall-open 参数：$1" ;; esac; done
  valid_port "$port" || die "端口格式无效"
  [[ "$proto" == "tcp" || "$proto" == "udp" ]] || die "协议格式无效"
  have ufw || die "未安装 ufw"
  run ufw allow in "${port}/${proto}" comment "vps-gateway manual open"
}
cmd_firewall_close() {
  require_root
  local port="" proto="tcp"
  while (($#)); do case "$1" in --port) port="$2"; shift 2 ;; --proto) proto="$2"; shift 2 ;; *) die "未知 firewall-close 参数：$1" ;; esac; done
  valid_port "$port" || die "端口格式无效"
  [[ "$proto" == "tcp" || "$proto" == "udp" ]] || die "协议格式无效"
  have ufw || die "未安装 ufw"
  [[ "$port" == "22" && "$proto" == "tcp" ]] && ssh443_verified || true
  if [[ "$port" == "22" && "$proto" == "tcp" && ! ssh443_verified ]]; then
    die "未标记 SSH over 443 验证成功，拒绝关闭 22。"
  fi
  local delete_rc=0
  if ((DRY_RUN)); then
    run ufw --force delete allow in "${port}/${proto}"
  else
    if ((VERBOSE)); then
      printf '+ ufw --force delete allow in %q\n' "${port}/${proto}"
    fi
    set +e
    ufw --force delete allow in "${port}/${proto}"
    delete_rc=$?
    set -e
    if [[ "$delete_rc" -ne 0 ]]; then
      warn "对应 allow 规则可能不存在，已继续添加 deny 规则。请用 ufw status numbered 手动确认。"
    fi
  fi
  run ufw deny in "${port}/${proto}"
}
cmd_firewall_only_443() { cmd_firewall_stage "$@"; }

cmd_fail2ban_install() { require_root; run apt-get update; run apt-get install -y fail2ban; }
cmd_fail2ban_config_ssh() {
  require_root
  init_layout
  local port
  port="$(/usr/sbin/sshd -T 2>/dev/null | awk '/^port /{print $2; exit}')"
  [[ -n "$port" ]] || port=22
  warn "如果 SSH 经 Nginx stream 转发，sshd 可能只看到来源 127.0.0.1；Fail2ban 可能无法封禁真实攻击源。"
  snapshot_module fail2ban >/dev/null
  write_file /etc/fail2ban/jail.d/vps-gateway-sshd.local <<EOF
[sshd]
enabled = true
port = ${port}
filter = sshd
logpath = /var/log/auth.log
maxretry = 5
findtime = 300
bantime = 600
EOF
  run systemctl enable --now fail2ban
  run systemctl restart fail2ban
}
cmd_fail2ban_status() { fail2ban-client status sshd 2>/dev/null || fail2ban-client status 2>/dev/null || true; }

cmd_login_notify_enable() {
  require_root
  init_layout
